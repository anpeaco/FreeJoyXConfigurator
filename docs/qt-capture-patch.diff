From: FreeJoyXConfigurator Slice 0.5 fixture capture
Subject: Throwaway dump-to-disk patch for hiddevice.cpp

Apply this patch to a clean checkout of FreeJoyXConfiguratorQt
(throwaway branch — do not commit, do not push). It adds a single
side-effect controlled by the env var FREEJOYX_DUMP_FIXTURE.

When the env var is set to a directory path:
  - Every incoming REPORT_ID_CONFIG_IN fragment (64 bytes incl.
    report-id + index header) is appended to
    $FREEJOYX_DUMP_FIXTURE/config.fragments.bin
  - The fully assembled dev_config_t (FREEJOY_DEV_CONFIG_SIZE bytes,
    1580 in v0.0.10) is written to
    $FREEJOYX_DUMP_FIXTURE/config.bin once "All config received" fires
  - Every successful REPORT_ID_PARAM packet (64 bytes incl. report-id)
    is appended to
    $FREEJOYX_DUMP_FIXTURE/params.bin

When the env var is unset, the build is identical to mainline Qt.

Usage from a Bash-on-Windows or PowerShell prompt:
  $env:FREEJOYX_DUMP_FIXTURE = "C:\path\to\FreeJoyXConfigurator\fixtures\_capture_wide"
  .\FreeJoyQt.exe
  # then click Read Config, wait for "All config received", move stick,
  # press buttons, etc., then close the app.

The capture is unconditionally appended, so delete the target
directory between runs to keep fixtures clean.

----------------------------------------------------------------------

diff --git a/src/hiddevice.cpp b/src/hiddevice.cpp
--- a/src/hiddevice.cpp
+++ b/src/hiddevice.cpp
@@ -1,6 +1,9 @@
 // existing includes ...
 #include "hiddevice.h"
+#include <QDir>
+#include <QFile>
+#include <QFileInfo>

 // ====================================================================
 // BEGIN throwaway fixture-capture helpers (FreeJoyXConfigurator port).
 // Remove before merging anywhere.
@@
+namespace {
+
+static QString fjxDumpDir()
+{
+    static const QString d = QString::fromLocal8Bit(qgetenv("FREEJOYX_DUMP_FIXTURE"));
+    return d;
+}
+
+static void fjxAppend(const QString &filename, const uint8_t *data, qsizetype len)
+{
+    const QString dir = fjxDumpDir();
+    if (dir.isEmpty()) return;
+    QDir().mkpath(dir);
+    QFile f(dir + "/" + filename);
+    if (!f.open(QIODevice::Append)) return;
+    f.write(reinterpret_cast<const char*>(data), len);
+    f.close();
+}
+
+static void fjxWrite(const QString &filename, const void *data, qsizetype len)
+{
+    const QString dir = fjxDumpDir();
+    if (dir.isEmpty()) return;
+    QDir().mkpath(dir);
+    QFile f(dir + "/" + filename);
+    if (!f.open(QIODevice::WriteOnly | QIODevice::Truncate)) return;
+    f.write(reinterpret_cast<const char*>(data), len);
+    f.close();
+}
+
+} // namespace
+// END throwaway fixture-capture helpers.
+
 // ... existing code ...

