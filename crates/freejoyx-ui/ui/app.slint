// FreeJoyXConfigurator Slint shell — Slice 5.
//
// Visual style per Style.MD: dark cockpit panel (#2a2a32) on near-black
// window, amber accent (#ffcc33), light-grey text, single 1 px borders.
// One Pins tab is implemented; other tabs render a "coming in Slice 6+"
// placeholder so the tab strip is visible.

// --- Palette ------------------------------------------------------------
//
// Theme switch. `dark` toggles every colour token between the dark
// cockpit palette and a light alternate. Rust side (settings.rs) loads
// the persisted choice at startup and writes it back when the Help
// menu's "Switch to … Mode" item is clicked.
export global Palette {
    in-out property <bool> dark: true;

    out property <color> bg-window: dark ? #000000 : #e8e8ec;
    out property <color> bg-panel: dark ? #2a2a32 : #f4f4f6;
    out property <color> bg-cell: dark ? #1a1a1e : #ffffff;
    out property <color> bg-cell-alt: dark ? #1e1e22 : #f8f8fa;
    out property <color> bg-cell-hover: dark ? #1f1f23 : #ececf0;
    out property <color> bg-pill: dark ? #1e1e22 : #ebebef;
    out property <color> bg-pill-hover: dark ? #2e2e34 : #dcdce0;
    out property <color> border: dark ? #3a3a44 : #c0c0c8;
    out property <color> text: dark ? #c8c8d0 : #1a1a1e;
    out property <color> text-dim: dark ? #8a8a96 : #5a5a64;
    out property <color> accent: dark ? #ffcc33 : #cc8800;
    out property <color> error: dark ? #d65a5a : #a02828;
    out property <color> error-bg: dark ? #553333 : #f4caca;
    out property <color> success: dark ? #6cb86c : #2a7a2a;
    out property <color> bg-warn: dark ? #4a3a1a : #fbe9bf;
}

// --- Lucide icon wrapper ------------------------------------------------
//
// A Lucide SVG re-tinted with the palette accent / text colour. The
// SVG ships with `stroke="#000"` so the femtovg-rasterised texture has
// alpha-correct strokes; `colorize` then multiplies the texture by
// `tint`. Default size 14 px matches the v0.1 toolbar's 13 px text.
component LucideIcon inherits Image {
    in property <length> size: 14px;
    in property <color> tint: Palette.text;
    width: root.size;
    height: root.size;
    colorize: root.tint;
    image-fit: contain;
    accessible-role: none;
}

// --- Reusable controls --------------------------------------------------
component PillButton inherits Rectangle {
    in property <string> label;
    in property <bool> enabled: true;
    in property <image> icon-source;
    in property <bool> show-chevron: false;
    callback clicked();

    height: 30px;
    min-width: 110px;
    background: ta.has-hover ? Palette.bg-pill-hover : Palette.bg-pill;
    border-color: Palette.border;
    border-width: 1px;
    border-radius: 4px;
    opacity: root.enabled ? 1.0 : 0.4;

    HorizontalLayout {
        alignment: center;
        padding-left: 12px;
        padding-right: 12px;
        spacing: 6px;
        LucideIcon {
            source: root.icon-source;
            tint: Palette.text;
            visible: root.icon-source.width > 0;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: root.label;
            color: Palette.text;
            font-size: 13px;
            vertical-alignment: center;
        }
        LucideIcon {
            source: @image-url("../assets/icons/chevron-down.svg");
            tint: Palette.text-dim;
            size: 12px;
            visible: root.show-chevron;
            y: (parent.height - self.height) / 2;
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component StatusDot inherits Rectangle {
    in property <bool> connected: false;
    width: 10px;
    height: 10px;
    border-radius: 5px;
    background: root.connected ? Palette.success : Palette.text-dim;
}

// --- Tab strip ----------------------------------------------------------
component TabButton inherits Rectangle {
    in property <string> label;
    in property <bool> selected: false;
    in property <bool> enabled: true;
    in property <image> icon-source;
    callback clicked();

    height: 36px;
    min-width: 120px;
    background: root.selected ? Palette.bg-panel : (ta.has-hover && root.enabled ? Palette.bg-cell-hover : Palette.bg-cell);
    border-color: root.selected ? Palette.accent : Palette.border;
    border-width: root.selected ? 2px : 1px;
    opacity: root.enabled ? 1.0 : 0.4;

    HorizontalLayout {
        alignment: center;
        padding-left: 14px;
        padding-right: 14px;
        spacing: 6px;
        LucideIcon {
            source: root.icon-source;
            tint: root.selected ? Palette.accent : Palette.text;
            size: 14px;
            visible: root.icon-source.width > 0;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: root.label;
            color: root.selected ? Palette.accent : Palette.text;
            font-size: 13px;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

// --- One pin row --------------------------------------------------------
//
// pin-name is the silkscreen label ("PA0"), function-label is the
// human-readable role name, function-index is the index into the
// global PinFunction list (used for the dropdown round-trip without
// inventing a Slint enum mirror), conflict-msg is non-empty when the
// validator flagged this row.
struct PinRow {
    pin-name: string,
    function-label: string,
    function-index: int,
    /// Visual family code from `PinFunctionFamily::to_u8` — drives the
    /// leading icon on the function cell. Values: 0=NotUsed, 1=Button,
    /// 2=Axis, 3=Encoder, 4=Bus, 5=Sensor, 6=ShiftReg, 7=Led, 8=RgbLed.
    function-family: int,
    conflict-msg: string,
    /// Short role abbreviation rendered on the board-view chip (e.g.
    /// "Btn", "Axis", "Enc"). Empty for `NotUsed`.
    family-short: string,
}

// Pick the Lucide SVG matching a `PinFunctionFamily` integer. Slint's
// `@image-url` is a compile-time literal so the dispatch has to be a
// chain — values match `PinFunctionFamily::to_u8` on the Rust side.
component PinFamilyIcon inherits LucideIcon {
    in property <int> family: 0;
    size: 14px;
    source:
        family == 1 ? @image-url("../assets/icons/square-mouse-pointer.svg") :
        family == 2 ? @image-url("../assets/icons/sliders-horizontal.svg") :
        family == 3 ? @image-url("../assets/icons/rotate-cw.svg") :
        family == 4 ? @image-url("../assets/icons/cable.svg") :
        family == 5 ? @image-url("../assets/icons/radar.svg") :
        family == 6 ? @image-url("../assets/icons/layers.svg") :
        family == 7 ? @image-url("../assets/icons/lightbulb.svg") :
        family == 8 ? @image-url("../assets/icons/palette.svg") :
        @image-url("../assets/icons/circle-dashed.svg");
}

component PinRowView inherits Rectangle {
    in property <PinRow> entry;
    in property <[string]> function-labels;
    in property <int> slot;
    in property <bool> selected: false;
    callback function-picked(int /* slot */, int /* new function index */);
    callback row-clicked();

    height: 36px;
    background: entry.conflict-msg != ""
        ? Palette.error-bg
        : (root.selected ? Palette.bg-warn : Palette.bg-cell);
    border-color: entry.conflict-msg != ""
        ? Palette.error
        : (root.selected ? Palette.accent : Palette.border);
    border-width: root.selected ? 2px : 1px;
    border-radius: 4px;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 12px;

        Text {
            text: root.entry.pin-name;
            color: Palette.text;
            font-size: 13px;
            width: 60px;
            vertical-alignment: center;
        }

        // Function picker — Slint's ComboBox lives in std-widgets;
        // re-import not needed since we use the global one if available.
        // For Slint 1.13 we use a plain combo via a TouchArea + Popup.
        // To keep this slice's surface area tight, we render the label
        // and use a click to advance through functions; the maintainer
        // can later swap in std-widgets ComboBox if desired.
        Rectangle {
            min-width: 240px;
            height: 28px;
            background: cycle-ta.has-hover ? Palette.bg-cell-hover : Palette.bg-cell-alt;
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 3px;
            vertical-stretch: 0;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 10px;
                spacing: 6px;
                PinFamilyIcon {
                    family: root.entry.function-family;
                    tint: root.entry.function-family == 0 ? Palette.text-dim : Palette.accent;
                    y: (parent.height - self.height) / 2;
                }
                Text {
                    text: root.entry.function-label;
                    color: Palette.text;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }

            cycle-ta := TouchArea {
                clicked => {
                    // Advance to next function — quick demo
                    // interaction without bringing in a full popup.
                    // Slice 5+ polish replaces with proper combobox.
                    root.function-picked(root.slot, mod(root.entry.function-index + 1, root.function-labels.length));
                }
            }
        }

        Rectangle {
            // Conflict badge
            visible: root.entry.conflict-msg != "";
            height: 22px;
            background: Palette.error;
            border-radius: 3px;
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 8px;
                spacing: 4px;
                alignment: center;
                LucideIcon {
                    source: @image-url("../assets/icons/alert-octagon.svg");
                    tint: #ffffff;
                    size: 12px;
                    y: (parent.height - self.height) / 2;
                }
                Text {
                    text: root.entry.conflict-msg;
                    color: #ffffff;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            // Spacer to push the row leftward
            horizontal-stretch: 1;
        }
    }
}

// --- Board-view pin chip -----------------------------------------------
//
// One pin chip on the schematic board view. Renders silkscreen label
// + family icon + short role abbreviation. Clicking highlights the
// pin's row in the list on the left.
component PinChip inherits Rectangle {
    in property <PinRow> entry;
    in property <int> slot;
    in property <bool> selected;
    callback clicked();

    height: 28px;
    background: ta.has-hover
        ? Palette.bg-cell-hover
        : (root.selected ? Palette.bg-warn : Palette.bg-cell);
    border-color: root.entry.conflict-msg != ""
        ? Palette.error
        : (root.selected ? Palette.accent : Palette.border);
    border-width: root.selected || root.entry.conflict-msg != "" ? 2px : 1px;
    border-radius: 3px;

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 4px;
        Text {
            text: root.entry.pin-name;
            color: Palette.text;
            font-size: 11px;
            font-weight: 600;
            width: 38px;
            vertical-alignment: center;
        }
        PinFamilyIcon {
            family: root.entry.function-family;
            tint: root.entry.function-family == 0 ? Palette.text-dim : Palette.accent;
            size: 12px;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: root.entry.family-short;
            color: root.entry.function-family == 0 ? Palette.text-dim : Palette.text;
            font-size: 10px;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Schematic two-column board view. Each side mirrors the silkscreen
// layout of a BluePill / BlackPill header strip — pins arranged in
// two vertical columns, top to bottom, USB end at the top. The
// 15-pin split (left: slots 0..14, right: slots 15..29) is close
// enough to the BluePill's PA-side / PB-side layout to give the user
// a "which side of the board" mental model without committing to
// pixel-perfect artwork.
component PinBoardView inherits Rectangle {
    in property <[PinRow]> pins;
    in property <int> highlighted-slot;
    callback chip-clicked(int /* slot */);

    background: Palette.bg-panel;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;
        Text {
            text: "Board view";
            color: Palette.text;
            font-size: 13px;
            font-weight: 600;
        }
        Text {
            text: "Click a pin to highlight its row. Red border = pin conflict.";
            color: Palette.text-dim;
            font-size: 10px;
            wrap: word-wrap;
        }
        Flickable {
            viewport-height: 15 * 32px;
            VerticalLayout {
                spacing: 2px;
                for r in 15: HorizontalLayout {
                    spacing: 6px;
                    if r < root.pins.length: PinChip {
                        entry: root.pins[r];
                        slot: r;
                        selected: root.highlighted-slot == r;
                        horizontal-stretch: 1;
                        clicked => { root.chip-clicked(r); }
                    }
                    if r + 15 < root.pins.length: PinChip {
                        entry: root.pins[r + 15];
                        slot: r + 15;
                        selected: root.highlighted-slot == r + 15;
                        horizontal-stretch: 1;
                        clicked => { root.chip-clicked(r + 15); }
                    }
                }
            }
        }
    }
}

// --- Pins tab body ------------------------------------------------------
component PinsTab inherits Rectangle {
    in property <[PinRow]> pins;
    in property <[string]> function-labels;
    in-out property <int> highlighted-slot: -1;
    callback pin-changed(int /* slot */, int /* function index */);

    background: Palette.bg-panel;

    VerticalLayout {
        padding: 16px;
        spacing: 6px;

        Text {
            text: "Pins";
            color: Palette.accent;
            font-size: 18px;
            font-weight: 600;
        }
        Text {
            text: "Left list maps each physical chip pin to a function — tap the function cell to cycle. Right is a schematic board view: click a chip to highlight the matching row. Pins in conflict (singleton roles claimed twice) get a red outline.";
            color: Palette.text-dim;
            font-size: 11px;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: 10px;
            vertical-stretch: 1;
            // Left half: existing list.
            Flickable {
                horizontal-stretch: 5;
                viewport-height: pins.length * 38px;
                VerticalLayout {
                    spacing: 2px;
                    for pin-data[i] in root.pins: PinRowView {
                        entry: pin-data;
                        slot: i;
                        function-labels: root.function-labels;
                        selected: root.highlighted-slot == i;
                        function-picked(slot, fn) => { root.pin-changed(slot, fn); }
                        row-clicked => { root.highlighted-slot = i; }
                    }
                }
            }
            // Right half: schematic board view.
            PinBoardView {
                horizontal-stretch: 4;
                pins: root.pins;
                highlighted-slot: root.highlighted-slot;
                chip-clicked(slot) => { root.highlighted-slot = slot; }
            }
        }
    }
}

// --- Axes tab ----------------------------------------------------------
//
// One row per axis (8 axes). The form surfaces only the v0.1 controls
// (Port.md §5 Slice 6): output / inverted / centered toggles,
// calibration min/center/max, filter level, deadband, resolution,
// channel. Sensor + axis-to-buttons stay raw in the codec for v0.1.
struct AxisRow {
    title: string,
    out-enabled: bool,
    inverted: bool,
    is-centered: bool,
    calib-min: int,
    calib-center: int,
    calib-max: int,
    filter-index: int,
    filter-label: string,
    deadband-size: int,
    is-dynamic-deadband: bool,
    resolution: int,
    channel: int,
    live-raw: int,
    live-out: int,
}

component CheckCell inherits Rectangle {
    in property <string> label;
    in property <bool> checked;
    /// When set, hide the trailing label so the cell is a bare
    /// check-square sized for a table column.
    in property <bool> compact: false;
    callback toggled();

    height: 26px;
    min-width: root.compact ? 26px : 70px;
    background: ta.has-hover ? Palette.bg-cell-hover : Palette.bg-cell-alt;
    border-color: root.checked ? Palette.accent : Palette.border;
    border-width: 1px;
    border-radius: 3px;

    HorizontalLayout {
        padding-left: root.compact ? 0px : 8px;
        padding-right: root.compact ? 0px : 8px;
        spacing: 6px;
        alignment: center;
        Rectangle {
            width: 12px;
            height: 12px;
            border-radius: 2px;
            border-color: Palette.border;
            border-width: 1px;
            background: root.checked ? Palette.accent : transparent;
            y: (parent.height - self.height) / 2;
        }
        if !root.compact: Text {
            text: root.label;
            color: Palette.text;
            font-size: 12px;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        clicked => { root.toggled(); }
    }
}

component NumberCell inherits Rectangle {
    in property <string> label;
    in property <int> value;
    in property <length> field-width: 70px;
    /// When set, suppress the leading label so the cell sits cleanly in a
    /// column under a header row.
    in property <bool> compact: false;
    callback edited(int);

    height: 26px;
    min-width: root.compact ? root.field-width : 110px;

    HorizontalLayout {
        spacing: 4px;
        alignment: start;

        if !root.compact: Text {
            text: root.label;
            color: Palette.text-dim;
            font-size: 11px;
            vertical-alignment: center;
        }

        Rectangle {
            width: root.field-width;
            height: 22px;
            background: Palette.bg-cell-alt;
            border-color: ti.has-focus ? Palette.accent : Palette.border;
            border-width: 1px;
            border-radius: 3px;
            y: (parent.height - self.height) / 2;

            ti := TextInput {
                text: root.value;
                color: Palette.text;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
                input-type: number;
                width: parent.width - 8px;
                x: 4px;
                edited => {
                    if (self.text == "" || self.text == "-") {
                        return;
                    }
                    root.edited(self.text.to-float());
                }
                accepted => { self.clear-focus(); }
            }
        }
    }
}

component CycleCell inherits Rectangle {
    in property <string> label;
    in property <string> value-label;
    in property <length> value-width: 100px;
    /// When set, drop the leading label and let the value pill fill
    /// the cell — for table layouts where the column header carries
    /// the label.
    in property <bool> compact: false;
    callback cycled();

    height: 26px;

    HorizontalLayout {
        spacing: 4px;
        alignment: start;
        if !root.compact: Text {
            text: root.label;
            color: Palette.text-dim;
            font-size: 11px;
            vertical-alignment: center;
        }
        Rectangle {
            width: root.value-width;
            height: 22px;
            background: ta.has-hover ? Palette.bg-cell-hover : Palette.bg-cell-alt;
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 3px;
            y: (parent.height - self.height) / 2;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                Text {
                    text: root.value-label;
                    color: Palette.text;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
            ta := TouchArea {
                clicked => { root.cycled(); }
            }
        }
    }
}

component AxisRowView inherits Rectangle {
    in property <AxisRow> entry;
    in property <int> slot;
    callback out-toggled(int);
    callback inverted-toggled(int);
    callback centered-toggled(int);
    callback calib-min-edited(int, int);
    callback calib-center-edited(int, int);
    callback calib-max-edited(int, int);
    callback filter-cycled(int);
    callback deadband-edited(int, int);
    callback dyn-deadband-toggled(int);
    callback resolution-cycled(int);
    callback channel-cycled(int);

    height: 110px;
    background: Palette.bg-cell;
    border-color: Palette.border;
    border-width: 1px;
    border-radius: 4px;

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            Text {
                text: root.entry.title;
                color: Palette.accent;
                font-size: 13px;
                font-weight: 600;
                vertical-alignment: center;
                width: 70px;
            }
            CheckCell {
                label: "Output";
                checked: root.entry.out-enabled;
                toggled => { root.out-toggled(root.slot); }
            }
            CheckCell {
                label: "Inverted";
                checked: root.entry.inverted;
                toggled => { root.inverted-toggled(root.slot); }
            }
            CheckCell {
                label: "Centered";
                checked: root.entry.is-centered;
                toggled => { root.centered-toggled(root.slot); }
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: "raw " + root.entry.live-raw + "    out " + root.entry.live-out;
                color: Palette.text-dim;
                font-size: 11px;
                vertical-alignment: center;
            }
        }

        HorizontalLayout {
            spacing: 8px;
            NumberCell {
                label: "min";
                value: root.entry.calib-min;
                field-width: 60px;
                edited(v) => { root.calib-min-edited(root.slot, v); }
            }
            NumberCell {
                label: "ctr";
                value: root.entry.calib-center;
                field-width: 60px;
                edited(v) => { root.calib-center-edited(root.slot, v); }
            }
            NumberCell {
                label: "max";
                value: root.entry.calib-max;
                field-width: 60px;
                edited(v) => { root.calib-max-edited(root.slot, v); }
            }
            CycleCell {
                label: "filter";
                value-label: root.entry.filter-label;
                value-width: 76px;
                cycled => { root.filter-cycled(root.slot); }
            }
            NumberCell {
                label: "dead";
                value: root.entry.deadband-size;
                field-width: 48px;
                edited(v) => { root.deadband-edited(root.slot, v); }
            }
            CheckCell {
                label: "Dyn";
                checked: root.entry.is-dynamic-deadband;
                toggled => { root.dyn-deadband-toggled(root.slot); }
            }
            CycleCell {
                label: "res";
                value-label: root.entry.resolution;
                value-width: 36px;
                cycled => { root.resolution-cycled(root.slot); }
            }
            CycleCell {
                label: "ch";
                value-label: root.entry.channel;
                value-width: 36px;
                cycled => { root.channel-cycled(root.slot); }
            }
            Rectangle { horizontal-stretch: 1; }
        }
    }
}

component AxesTab inherits Rectangle {
    in property <[AxisRow]> axes;
    callback out-toggled(int);
    callback inverted-toggled(int);
    callback centered-toggled(int);
    callback calib-min-edited(int, int);
    callback calib-center-edited(int, int);
    callback calib-max-edited(int, int);
    callback filter-cycled(int);
    callback deadband-edited(int, int);
    callback dyn-deadband-toggled(int);
    callback resolution-cycled(int);
    callback channel-cycled(int);

    background: Palette.bg-panel;

    VerticalLayout {
        padding: 16px;
        spacing: 6px;

        Text {
            text: "Axes";
            color: Palette.accent;
            font-size: 18px;
            font-weight: 600;
        }
        Text {
            text: "Linear calibration, filter, deadband, resolution, channel. Live raw and processed values stream from the device.";
            color: Palette.text-dim;
            font-size: 11px;
            wrap: word-wrap;
        }

        Flickable {
            viewport-height: axes.length * 116px;
            VerticalLayout {
                spacing: 4px;
                for axis-data[i] in root.axes: AxisRowView {
                    entry: axis-data;
                    slot: i;
                    out-toggled(s) => { root.out-toggled(s); }
                    inverted-toggled(s) => { root.inverted-toggled(s); }
                    centered-toggled(s) => { root.centered-toggled(s); }
                    calib-min-edited(s, v) => { root.calib-min-edited(s, v); }
                    calib-center-edited(s, v) => { root.calib-center-edited(s, v); }
                    calib-max-edited(s, v) => { root.calib-max-edited(s, v); }
                    filter-cycled(s) => { root.filter-cycled(s); }
                    deadband-edited(s, v) => { root.deadband-edited(s, v); }
                    dyn-deadband-toggled(s) => { root.dyn-deadband-toggled(s); }
                    resolution-cycled(s) => { root.resolution-cycled(s); }
                    channel-cycled(s) => { root.channel-cycled(s); }
                }
            }
        }
    }
}

// --- Buttons tab -------------------------------------------------------
//
// 128 button slots. Each row carries:
//
//   slot # | physical input | type cycle | shift cycle | inverted | disabled | live
//
// LOGIC slots reveal a second row for op + source B + debounce timer
// + validator badge. The per-physical coexistence rule
// (F103_GESTURE_PLAN.md: only NORMAL/TAP/DOUBLE_TAP may share a
// physical) is enforced by `physical_assignment_blocked` in
// freejoyx-core::domain::buttons — if the user tries to step the
// type cycle to a blocked variant, the cycle skips past it.
struct ButtonRow {
    // Wire slot index (0..127). The model can be filtered or reordered,
    // so the for-loop position is no longer authoritative for callbacks.
    slot: int,
    physical-num: int,
    type-label: string,
    type-index: int,
    is-logic: bool,
    shift-modificator: int,
    is-inverted: bool,
    is-disabled: bool,
    // LOGIC-only fields (ignored when is-logic == false)
    src-b: int,
    op-label: string,
    op-index: int,
    debounce-label: string,
    debounce-index: int,
    logic-error: string,
    // Live state
    phy-pressed: bool,
    log-pressed: bool,
}

// One row in the category-grouped button-type picker. Headers
// (`is-header: true`) carry only `label`; entries carry `label` and
// `type-index` (the wire byte). Built once on the Rust side from
// `ButtonTypeCategory::entries()`.
struct TypePickerEntry {
    is-header: bool,
    label: string,
    type-index: int,
}

// Per-slot blocked-ness for each entry — kept as a separate flat list
// because Slint structs can't nest array fields. Length matches the
// entries model (so header rows carry `blocked: false`, ignored).
struct TypeBlockedInfo {
    blocked: bool,
    reason: string,
}

component LiveDot inherits Rectangle {
    in property <bool> on;
    in property <color> on-color: Palette.accent;
    width: 10px;
    height: 10px;
    border-radius: 5px;
    background: root.on ? root.on-color : Palette.bg-cell-alt;
    border-color: Palette.border;
    border-width: 1px;
}

// Column widths for the Buttons + Logic table. Header cells and row
// cells both pull from these so the grid stays aligned regardless of
// the value rendered inside.
export global BtnCols {
    out property <length> w-num: 32px;
    out property <length> w-phy: 56px;
    out property <length> w-type: 144px;
    out property <length> w-shift: 36px;
    out property <length> w-inv: 38px;
    out property <length> w-dis: 38px;
    out property <length> w-live: 30px;
    out property <length> spacing: 8px;
    // Logic sub-row columns. Offsets sit under the main row's Type
    // column (so logic operands feel attached to the slot type).
    out property <length> w-op: 96px;
    out property <length> w-srcb: 52px;
    out property <length> w-debounce: 76px;
}

// Button-type opener cell — same visual mass as a `CycleCell`-in-compact
// mode, but a click opens the category-grouped picker rather than
// stepping the cycle.
component TypePickerCell inherits Rectangle {
    in property <string> value-label;
    in property <length> value-width: 100px;
    callback opened();

    height: 26px;

    Rectangle {
        width: root.value-width;
        height: 22px;
        background: ta.has-hover ? Palette.bg-cell-hover : Palette.bg-cell-alt;
        border-color: Palette.border;
        border-width: 1px;
        border-radius: 3px;
        x: 0;
        y: (parent.height - self.height) / 2;
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 6px;
            spacing: 4px;
            alignment: start;
            Text {
                text: root.value-label;
                color: Palette.text;
                font-size: 12px;
                vertical-alignment: center;
            }
            Rectangle { horizontal-stretch: 1; }
            LucideIcon {
                source: @image-url("../assets/icons/chevron-down.svg");
                tint: Palette.text-dim;
                size: 10px;
                y: (parent.height - self.height) / 2;
            }
        }
        ta := TouchArea {
            clicked => { root.opened(); }
        }
    }
}

component HeaderCell inherits Rectangle {
    in property <string> text;
    in property <length> col-width: 32px;
    in property <TextHorizontalAlignment> hpad: TextHorizontalAlignment.left;
    width: root.col-width;
    Text {
        text: root.text;
        color: Palette.text-dim;
        font-size: 10px;
        letter-spacing: 0.4px;
        horizontal-alignment: root.hpad;
        vertical-alignment: center;
        width: 100%;
        height: 100%;
    }
}

component ButtonRowView inherits Rectangle {
    in property <ButtonRow> entry;
    in property <int> slot;
    callback physical-edited(int /* slot */, int /* new value */);
    callback type-picker-opened(int);
    callback shift-cycled(int);
    callback inverted-toggled(int);
    callback disabled-toggled(int);
    callback src-b-edited(int, int);
    callback op-cycled(int);
    callback debounce-cycled(int);

    height: root.entry.is-logic ? 70px : 36px;
    background: Palette.bg-cell;
    border-color: root.entry.logic-error != "" ? Palette.error : Palette.border;
    border-width: 1px;
    border-radius: 4px;

    VerticalLayout {
        padding-left: 6px;
        padding-right: 6px;
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 2px;

        HorizontalLayout {
            spacing: BtnCols.spacing;
            alignment: start;
            HeaderCell {
                text: (root.slot + 1) + ".";
                col-width: BtnCols.w-num;
                hpad: TextHorizontalAlignment.right;
            }
            NumberCell {
                compact: true;
                value: root.entry.physical-num;
                field-width: BtnCols.w-phy;
                edited(v) => { root.physical-edited(root.slot, v); }
            }
            TypePickerCell {
                value-label: root.entry.type-label;
                value-width: BtnCols.w-type;
                opened => { root.type-picker-opened(root.slot); }
            }
            CycleCell {
                compact: true;
                value-label: root.entry.shift-modificator;
                value-width: BtnCols.w-shift;
                cycled => { root.shift-cycled(root.slot); }
            }
            CheckCell {
                compact: true;
                checked: root.entry.is-inverted;
                toggled => { root.inverted-toggled(root.slot); }
            }
            CheckCell {
                compact: true;
                checked: root.entry.is-disabled;
                toggled => { root.disabled-toggled(root.slot); }
            }
            Rectangle { horizontal-stretch: 1; }
            HorizontalLayout {
                spacing: 4px;
                width: BtnCols.w-live;
                alignment: center;
                LiveDot {
                    on: root.entry.phy-pressed;
                    y: (parent.height - self.height) / 2;
                }
                LiveDot {
                    on: root.entry.log-pressed;
                    on-color: Palette.success;
                    y: (parent.height - self.height) / 2;
                }
            }
        }

        if root.entry.is-logic: HorizontalLayout {
            spacing: BtnCols.spacing;
            alignment: start;
            // Offset under the Type column.
            Rectangle { width: BtnCols.w-num + BtnCols.spacing + BtnCols.w-phy; }
            CycleCell {
                compact: true;
                value-label: root.entry.op-label;
                value-width: BtnCols.w-op;
                cycled => { root.op-cycled(root.slot); }
            }
            NumberCell {
                compact: true;
                value: root.entry.src-b;
                field-width: BtnCols.w-srcb;
                edited(v) => { root.src-b-edited(root.slot, v); }
            }
            CycleCell {
                compact: true;
                value-label: root.entry.debounce-label;
                value-width: BtnCols.w-debounce;
                cycled => { root.debounce-cycled(root.slot); }
            }
            Rectangle {
                visible: root.entry.logic-error != "";
                height: 22px;
                background: Palette.error;
                border-radius: 3px;
                HorizontalLayout {
                    padding-left: 6px;
                    padding-right: 8px;
                    spacing: 4px;
                    alignment: center;
                    LucideIcon {
                        source: @image-url("../assets/icons/alert-octagon.svg");
                        tint: #ffffff;
                        size: 12px;
                        y: (parent.height - self.height) / 2;
                    }
                    Text {
                        text: root.entry.logic-error;
                        color: #ffffff;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }
            Rectangle { horizontal-stretch: 1; }
        }
    }
}

// Column-header strip for the Buttons + Logic table. Sits above the
// Flickable so it stays visible while the rows scroll.
component ButtonsHeaderRow inherits Rectangle {
    height: 24px;
    background: Palette.bg-panel;
    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: BtnCols.spacing;
        HeaderCell { text: "#"; col-width: BtnCols.w-num; hpad: TextHorizontalAlignment.right; }
        HeaderCell { text: "PHYSICAL"; col-width: BtnCols.w-phy; }
        HeaderCell { text: "TYPE"; col-width: BtnCols.w-type; }
        HeaderCell { text: "SHIFT"; col-width: BtnCols.w-shift; hpad: TextHorizontalAlignment.center; }
        HeaderCell { text: "INV"; col-width: BtnCols.w-inv; hpad: TextHorizontalAlignment.center; }
        HeaderCell { text: "DIS"; col-width: BtnCols.w-dis; hpad: TextHorizontalAlignment.center; }
        Rectangle { horizontal-stretch: 1; }
        HeaderCell { text: "LIVE"; col-width: BtnCols.w-live; hpad: TextHorizontalAlignment.center; }
    }
    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: Palette.border;
    }
}

component ButtonsTab inherits Rectangle {
    in property <[ButtonRow]> buttons;
    // Filter state (issue #5) — passed from AppWindow so the Rust side
    // can mutate freely and the strip below reflects the truth.
    in property <bool> hide-unused;
    in property <int> filter-physical;  // -1 when not filtering
    in property <string> filter-category-label;  // "All" when not filtering
    in property <int> visible-count;
    callback physical-edited(int, int);
    callback type-picker-opened(int);
    callback shift-cycled(int);
    callback inverted-toggled(int);
    callback disabled-toggled(int);
    callback src-b-edited(int, int);
    callback op-cycled(int);
    callback debounce-cycled(int);
    callback hide-unused-toggled();
    callback filter-physical-edited(int);
    callback filter-physical-cleared();
    callback filter-category-cycled();
    callback add-button-clicked();

    background: Palette.bg-panel;

    VerticalLayout {
        padding: 16px;
        spacing: 6px;

        Text {
            text: "Buttons + Logic";
            color: Palette.accent;
            font-size: 18px;
            font-weight: 600;
        }
        Text {
            text: "128 button slots. Click the Type cell to pick from category groups; blocked types are greyed with the conflicting slot's name. LOGIC rows expose op / Source B / debounce in a sub-row under the Type column. Amber dot = physical pressed; green dot = logical state.";
            color: Palette.text-dim;
            font-size: 11px;
            wrap: word-wrap;
        }

        // Filter strip (issue #5).
        Rectangle {
            height: 32px;
            background: Palette.bg-cell;
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 4px;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 10px;
                alignment: start;
                LucideIcon {
                    source: @image-url("../assets/icons/filter.svg");
                    tint: Palette.text-dim;
                    size: 14px;
                    y: (parent.height - self.height) / 2;
                }
                CheckCell {
                    label: "Hide unused";
                    checked: root.hide-unused;
                    toggled => { root.hide-unused-toggled(); }
                }
                NumberCell {
                    label: "Physical";
                    value: root.filter-physical;
                    field-width: 56px;
                    edited(v) => { root.filter-physical-edited(v); }
                }
                if root.filter-physical >= 0: Rectangle {
                    width: 22px;
                    height: 22px;
                    y: (parent.height - self.height) / 2;
                    background: clr-ta.has-hover ? Palette.bg-cell-hover : transparent;
                    border-radius: 3px;
                    LucideIcon {
                        source: @image-url("../assets/icons/x.svg");
                        tint: Palette.text-dim;
                        size: 12px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                    clr-ta := TouchArea {
                        clicked => { root.filter-physical-cleared(); }
                    }
                }
                CycleCell {
                    label: "Type";
                    value-label: root.filter-category-label;
                    value-width: 116px;
                    cycled => { root.filter-category-cycled(); }
                }
                Rectangle { horizontal-stretch: 1; }
                Text {
                    text: root.visible-count + " / 128";
                    color: Palette.text-dim;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                PillButton {
                    label: "Add button";
                    icon-source: @image-url("../assets/icons/plus.svg");
                    clicked => { root.add-button-clicked(); }
                }
            }
        }

        ButtonsHeaderRow { }

        Flickable {
            // 38 px for a plain row, 72 px when the LOGIC sub-row is visible.
            // Pre-compute a conservative bound rather than a per-row sum:
            // 128 × 72 = 9216 px will always cover, regardless of LOGIC mix.
            viewport-height: buttons.length * 72px;
            VerticalLayout {
                spacing: 2px;
                for btn-data[i] in root.buttons: ButtonRowView {
                    entry: btn-data;
                    slot: btn-data.slot;
                    physical-edited(s, v) => { root.physical-edited(s, v); }
                    type-picker-opened(s) => { root.type-picker-opened(s); }
                    shift-cycled(s) => { root.shift-cycled(s); }
                    inverted-toggled(s) => { root.inverted-toggled(s); }
                    disabled-toggled(s) => { root.disabled-toggled(s); }
                    src-b-edited(s, v) => { root.src-b-edited(s, v); }
                    op-cycled(s) => { root.op-cycled(s); }
                    debounce-cycled(s) => { root.debounce-cycled(s); }
                }
            }
        }
    }
}

// --- Shifts & Timers tab -----------------------------------------------
struct ShiftSlot {
    label: string,
    button-index: int,
}

struct TimerField {
    label: string,
    hint: string,
    value-ms: int,
}

component ShiftsTimersTab inherits Rectangle {
    in property <[ShiftSlot]> shifts;
    in property <[TimerField]> timers;
    callback shift-edited(int /* slot */, int /* button index */);
    callback timer-edited(int /* index */, int /* ms */);

    background: Palette.bg-panel;

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        Text {
            text: "Shifts & Timers";
            color: Palette.accent;
            font-size: 18px;
            font-weight: 600;
        }
        Text {
            text: "Shifts pick the button index that activates each modifier slot (−1 = unused). Timers configure debounce / tap windows; values are in milliseconds.";
            color: Palette.text-dim;
            font-size: 11px;
            wrap: word-wrap;
        }

        Text {
            text: "Shift modifier slots";
            color: Palette.text;
            font-size: 13px;
            font-weight: 600;
        }
        for shift-data[i] in root.shifts: Rectangle {
            height: 30px;
            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: shift-data.label;
                    color: Palette.text;
                    font-size: 12px;
                    width: 80px;
                    vertical-alignment: center;
                }
                NumberCell {
                    label: "button";
                    value: shift-data.button-index;
                    field-width: 64px;
                    edited(v) => { root.shift-edited(i, v); }
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }

        Rectangle { height: 8px; }
        Text {
            text: "Global timers (ms)";
            color: Palette.text;
            font-size: 13px;
            font-weight: 600;
        }
        for timer-data[i] in root.timers: Rectangle {
            height: 30px;
            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: timer-data.label;
                    color: Palette.text;
                    font-size: 12px;
                    width: 130px;
                    vertical-alignment: center;
                }
                NumberCell {
                    label: "ms";
                    value: timer-data.value-ms;
                    field-width: 72px;
                    edited(v) => { root.timer-edited(i, v); }
                }
                Text {
                    text: timer-data.hint;
                    color: Palette.text-dim;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}

// --- Encoders tab ------------------------------------------------------
//
// 16 soft encoder slots (each: mode 1x/2x/4x) plus 2 fast encoder
// slots (enabled flag + mode). Fast encoder pins are silicon-locked on
// F103 (PA8/PA9 = Fast 1, PB6/PB7 = Fast 2) so they're configured by
// setting the FastEncoder PinFunction on those pins via the Pins tab,
// not here.
struct EncoderRow {
    label: string,
    mode-label: string,
    mode-index: int,
}

struct FastEncoderRow {
    label: string,
    enabled: bool,
    mode-label: string,
    mode-index: int,
    hint: string,
}

component EncodersTab inherits Rectangle {
    in property <[EncoderRow]> soft;
    in property <[FastEncoderRow]> fast;
    callback soft-mode-cycled(int);
    callback fast-enabled-toggled(int);
    callback fast-mode-cycled(int);

    background: Palette.bg-panel;

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        Text {
            text: "Encoders";
            color: Palette.accent;
            font-size: 18px;
            font-weight: 600;
        }
        Text {
            text: "Soft encoders wire two button slots (type ENCODER_INPUT_A / B) to a software quadrature decoder. Fast encoders use the F103's hardware timers — pins are silicon-locked (PA8/PA9 = Fast 1, PB6/PB7 = Fast 2) and assigned via the Pins tab.";
            color: Palette.text-dim;
            font-size: 11px;
            wrap: word-wrap;
        }

        Text {
            text: "Fast (hardware) encoders";
            color: Palette.text;
            font-size: 13px;
            font-weight: 600;
        }
        for fast-data[i] in root.fast: Rectangle {
            height: 32px;
            background: Palette.bg-cell;
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 4px;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                Text {
                    text: fast-data.label;
                    color: Palette.text;
                    font-size: 12px;
                    width: 80px;
                    vertical-alignment: center;
                }
                CheckCell {
                    label: "Enabled";
                    checked: fast-data.enabled;
                    toggled => { root.fast-enabled-toggled(i); }
                }
                CycleCell {
                    label: "mode";
                    value-label: fast-data.mode-label;
                    value-width: 50px;
                    cycled => { root.fast-mode-cycled(i); }
                }
                Text {
                    text: fast-data.hint;
                    color: Palette.text-dim;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }

        Rectangle { height: 8px; }
        Text {
            text: "Soft (software) encoders";
            color: Palette.text;
            font-size: 13px;
            font-weight: 600;
        }
        Flickable {
            viewport-height: soft.length * 30px;
            VerticalLayout {
                spacing: 2px;
                for soft-data[i] in root.soft: Rectangle {
                    height: 28px;
                    background: Palette.bg-cell;
                    border-color: Palette.border;
                    border-width: 1px;
                    border-radius: 3px;
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        spacing: 8px;
                        Text {
                            text: soft-data.label;
                            color: Palette.text;
                            font-size: 12px;
                            width: 80px;
                            vertical-alignment: center;
                        }
                        CycleCell {
                            label: "mode";
                            value-label: soft-data.mode-label;
                            value-width: 50px;
                            cycled => { root.soft-mode-cycled(i); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }
            }
        }
    }
}

// --- Shift Registers tab ----------------------------------------------
struct ShiftRegRow {
    label: string,
    type-label: string,
    type-index: int,
    button-count: int,
}

component ShiftRegsTab inherits Rectangle {
    in property <[ShiftRegRow]> registers;
    callback type-cycled(int);
    callback count-edited(int, int);

    background: Palette.bg-panel;

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        Text {
            text: "Shift Registers";
            color: Palette.accent;
            font-size: 18px;
            font-weight: 600;
        }
        Text {
            text: "Up to four daisy-chained HC165 or CD4021 shift registers. Latch / data / clock pins are assigned via the Pins tab (ShiftRegLatch / ShiftRegData / ShiftRegClk).";
            color: Palette.text-dim;
            font-size: 11px;
            wrap: word-wrap;
        }

        for reg-data[i] in root.registers: Rectangle {
            height: 36px;
            background: Palette.bg-cell;
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 4px;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                Text {
                    text: reg-data.label;
                    color: Palette.text;
                    font-size: 12px;
                    width: 60px;
                    vertical-alignment: center;
                }
                CycleCell {
                    label: "type";
                    value-label: reg-data.type-label;
                    value-width: 140px;
                    cycled => { root.type-cycled(i); }
                }
                NumberCell {
                    label: "buttons";
                    value: reg-data.button-count;
                    field-width: 56px;
                    edited(v) => { root.count-edited(i, v); }
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}

// --- Advanced Settings tab --------------------------------------------
//
// Device-name (up to 26 bytes), VID, PID. Firmware version and board
// id are rendered read-only — they come straight off the wire. The
// device picker is in the toolbar; this tab is for fields that are
// persisted on the connected board.
struct AdvancedModel {
    device-name: string,
    vid-hex: string,
    pid-hex: string,
    firmware-version-hex: string,
    board-id: int,
    freejoyx-version: string,
}

component AdvancedTab inherits Rectangle {
    in property <AdvancedModel> data;
    callback name-edited(string);
    callback vid-edited(string);
    callback pid-edited(string);

    background: Palette.bg-panel;

    VerticalLayout {
        padding: 16px;
        spacing: 10px;

        Text {
            text: "Advanced Settings";
            color: Palette.accent;
            font-size: 18px;
            font-weight: 600;
        }
        Text {
            text: "Device identification persisted on the board. VID and PID accept hex (e.g. 0483). Firmware version and board id are read-only.";
            color: Palette.text-dim;
            font-size: 11px;
            wrap: word-wrap;
        }

        // Device name
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "Device name";
                color: Palette.text;
                font-size: 12px;
                width: 130px;
                vertical-alignment: center;
            }
            Rectangle {
                width: 280px;
                height: 26px;
                background: Palette.bg-cell-alt;
                border-color: name-ti.has-focus ? Palette.accent : Palette.border;
                border-width: 1px;
                border-radius: 3px;
                name-ti := TextInput {
                    text: root.data.device-name;
                    color: Palette.text;
                    font-size: 12px;
                    vertical-alignment: center;
                    width: parent.width - 12px;
                    x: 6px;
                    edited => { root.name-edited(self.text); }
                    accepted => { self.clear-focus(); }
                }
            }
            Text {
                text: "max 26 bytes";
                color: Palette.text-dim;
                font-size: 11px;
                vertical-alignment: center;
            }
        }

        // VID
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "USB VID";
                color: Palette.text;
                font-size: 12px;
                width: 130px;
                vertical-alignment: center;
            }
            Rectangle {
                width: 100px;
                height: 26px;
                background: Palette.bg-cell-alt;
                border-color: vid-ti.has-focus ? Palette.accent : Palette.border;
                border-width: 1px;
                border-radius: 3px;
                vid-ti := TextInput {
                    text: root.data.vid-hex;
                    color: Palette.text;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    width: parent.width - 12px;
                    x: 6px;
                    edited => { root.vid-edited(self.text); }
                    accepted => { self.clear-focus(); }
                }
            }
            Text {
                text: "hex (0..ffff)";
                color: Palette.text-dim;
                font-size: 11px;
                vertical-alignment: center;
            }
        }

        // PID
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "USB PID";
                color: Palette.text;
                font-size: 12px;
                width: 130px;
                vertical-alignment: center;
            }
            Rectangle {
                width: 100px;
                height: 26px;
                background: Palette.bg-cell-alt;
                border-color: pid-ti.has-focus ? Palette.accent : Palette.border;
                border-width: 1px;
                border-radius: 3px;
                pid-ti := TextInput {
                    text: root.data.pid-hex;
                    color: Palette.text;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    width: parent.width - 12px;
                    x: 6px;
                    edited => { root.pid-edited(self.text); }
                    accepted => { self.clear-focus(); }
                }
            }
            Text {
                text: "hex (0..ffff)";
                color: Palette.text-dim;
                font-size: 11px;
                vertical-alignment: center;
            }
        }

        Rectangle { height: 8px; }
        Text {
            text: "Read-only";
            color: Palette.text;
            font-size: 13px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "Firmware version";
                color: Palette.text-dim;
                font-size: 12px;
                width: 130px;
                vertical-alignment: center;
            }
            Text {
                text: root.data.firmware-version-hex;
                color: Palette.text;
                font-size: 12px;
                vertical-alignment: center;
            }
        }
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "Board id";
                color: Palette.text-dim;
                font-size: 12px;
                width: 130px;
                vertical-alignment: center;
            }
            Text {
                text: root.data.board-id;
                color: Palette.text;
                font-size: 12px;
                vertical-alignment: center;
            }
        }
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "FreeJoyX build";
                color: Palette.text-dim;
                font-size: 12px;
                width: 130px;
                vertical-alignment: center;
            }
            Text {
                text: root.data.freejoyx-version;
                color: Palette.text;
                font-size: 12px;
                vertical-alignment: center;
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}

// --- Device picker (toolbar popup row) ---------------------------------
struct DeviceOption {
    label: string,
    serial: string,
    is-current: bool,
}

component DevicePickerRow inherits Rectangle {
    in property <DeviceOption> entry;
    callback picked();

    height: 30px;
    background: ta.has-hover ? Palette.bg-cell-hover : Palette.bg-cell;
    border-color: root.entry.is-current ? Palette.accent : Palette.border;
    border-width: 1px;
    border-radius: 3px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        Rectangle {
            width: 8px;
            height: 8px;
            border-radius: 4px;
            background: root.entry.is-current ? Palette.accent : transparent;
            border-color: Palette.border;
            border-width: 1px;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: root.entry.label;
            color: Palette.text;
            font-size: 12px;
            vertical-alignment: center;
        }
        Rectangle { horizontal-stretch: 1; }
    }

    ta := TouchArea {
        clicked => { root.picked(); }
    }
}

// --- Toast banner -------------------------------------------------------
//
// Persistent message strip rendered between the toolbar and the tab
// row when `severity > 0`. Used for unrecoverable / user-actionable
// conditions that the auto-rotating status-text line at the bottom of
// the toolbar can't carry — most importantly the unsupported-firmware
// gate. Dismissible by the X on the right; an `error` toast survives
// until the underlying condition clears, then the app clears it on the
// caller's behalf.
component ToastBanner inherits Rectangle {
    in property <int> severity; // 1=info, 2=warn, 3=error
    in property <string> message;
    callback dismissed();

    height: 36px;
    background:
        root.severity == 3 ? Palette.error-bg
        : root.severity == 2 ? Palette.bg-warn
        : Palette.bg-cell;
    border-color:
        root.severity == 3 ? Palette.error
        : root.severity == 2 ? Palette.accent
        : Palette.border;
    border-width: 1px;
    border-radius: 4px;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 8px;
        spacing: 10px;
        LucideIcon {
            source:
                root.severity == 3 ? @image-url("../assets/icons/circle-alert.svg")
                : root.severity == 2 ? @image-url("../assets/icons/triangle-alert.svg")
                : @image-url("../assets/icons/info.svg");
            tint:
                root.severity == 3 ? Palette.error
                : root.severity == 2 ? Palette.accent
                : Palette.text-dim;
            size: 16px;
            y: (parent.height - self.height) / 2;
        }
        Text {
            text: root.message;
            color: Palette.text;
            font-size: 12px;
            vertical-alignment: center;
            wrap: word-wrap;
            horizontal-stretch: 1;
        }
        Rectangle {
            width: 24px;
            height: 24px;
            y: (parent.height - self.height) / 2;
            background: dismiss-ta.has-hover ? Palette.bg-cell-hover : transparent;
            border-radius: 3px;
            LucideIcon {
                source: @image-url("../assets/icons/x.svg");
                tint: Palette.text-dim;
                size: 12px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
            }
            dismiss-ta := TouchArea {
                clicked => { root.dismissed(); }
            }
        }
    }
}

// --- Button-type picker overlay ----------------------------------------
//
// Modal-style centred picker. Slint popups are awkward to position
// near a specific cell across a scrolling Flickable, so we use a
// dialog-style overlay (matching the AboutDialog pattern). Blocked
// entries grey out and surface the reason inline so the user sees
// *why* a choice is rejected instead of the old cycle silently
// skipping past it.
component TypePickerOverlay inherits Rectangle {
    in property <[TypePickerEntry]> entries;
    in property <[TypeBlockedInfo]> blocked-info;
    in property <int> slot;
    in property <int> current-type-index;
    callback picked(int /* slot */, int /* type-index */);
    callback dismissed();

    background: #00000088;

    TouchArea {
        clicked => { root.dismissed(); }
    }

    Rectangle {
        background: Palette.bg-panel;
        border-color: Palette.border;
        border-width: 1px;
        border-radius: 8px;
        width: 360px;
        height: 560px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;

        // Block clicks from falling through to the backdrop.
        TouchArea { }

        VerticalLayout {
            padding: 14px;
            spacing: 6px;
            Text {
                text: "Pick button function";
                color: Palette.accent;
                font-size: 14px;
                font-weight: 600;
            }
            Text {
                text: "Greyed entries conflict with another slot on the same physical input.";
                color: Palette.text-dim;
                font-size: 10px;
                wrap: word-wrap;
            }
            Rectangle { height: 2px; }
            Flickable {
                vertical-stretch: 1;
                viewport-height: root.entries.length * 26px;
                VerticalLayout {
                    spacing: 1px;
                    for entry[i] in root.entries: Rectangle {
                        height: entry.is-header ? 22px : 24px;
                        property <bool> is-blocked: !entry.is-header
                            && root.blocked-info[entry.type-index].blocked;
                        property <bool> is-current: !entry.is-header
                            && entry.type-index == root.current-type-index;
                        background: entry.is-header
                            ? transparent
                            : (entry-ta.has-hover && !is-blocked
                                ? Palette.bg-cell-hover
                                : (is-current ? Palette.bg-cell-alt : transparent));
                        border-color: is-current ? Palette.accent : transparent;
                        border-width: is-current ? 1px : 0px;
                        border-radius: 3px;
                        HorizontalLayout {
                            padding-left: entry.is-header ? 4px : 22px;
                            padding-right: 8px;
                            spacing: 6px;
                            alignment: start;
                            Text {
                                text: entry.label;
                                color: entry.is-header
                                    ? Palette.text-dim
                                    : (is-blocked ? Palette.text-dim
                                       : (is-current ? Palette.accent : Palette.text));
                                font-size: entry.is-header ? 10px : 12px;
                                font-weight: entry.is-header ? 600 : 400;
                                letter-spacing: entry.is-header ? 0.5px : 0px;
                                vertical-alignment: center;
                            }
                            Rectangle { horizontal-stretch: 1; }
                            if !entry.is-header && is-blocked: Text {
                                text: root.blocked-info[entry.type-index].reason;
                                color: Palette.text-dim;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                        }
                        entry-ta := TouchArea {
                            enabled: !entry.is-header && !is-blocked;
                            clicked => { root.picked(root.slot, entry.type-index); }
                        }
                    }
                }
            }
            Rectangle { height: 4px; }
            HorizontalLayout {
                alignment: end;
                PillButton {
                    label: "Cancel";
                    clicked => { root.dismissed(); }
                }
            }
        }
    }
}

// --- About dialog -------------------------------------------------------
component AboutDialog inherits Rectangle {
    in property <string> app-version;
    in property <string> build-rev;
    in property <string> supported-fw;
    callback closed();

    background: Palette.bg-panel;
    border-color: Palette.border;
    border-width: 1px;
    border-radius: 8px;
    width: 480px;
    height: 320px;

    VerticalLayout {
        padding: 20px;
        spacing: 8px;
        Text {
            text: "FreeJoyXConfigurator";
            color: Palette.accent;
            font-size: 18px;
            font-weight: 700;
        }
        Text {
            text: "Version " + root.app-version + " (" + root.build-rev + ")";
            color: Palette.text;
            font-size: 12px;
        }
        Rectangle { height: 8px; }
        Text {
            text: "Native Rust + Slint configurator for FreeJoyX firmware.";
            color: Palette.text;
            font-size: 12px;
            wrap: word-wrap;
        }
        Text {
            text: "Supports firmware mask group 0x" + root.supported-fw + ". For legacy upstream FreeJoy boards on the 0x17XX line, use the Qt configurator (FreeJoyConfiguratorQt).";
            color: Palette.text-dim;
            font-size: 11px;
            wrap: word-wrap;
        }
        Rectangle { height: 8px; }
        Text {
            text: "Licensed GPLv3. Source: github.com/anpeaco/FreeJoyXConfigurator";
            color: Palette.text-dim;
            font-size: 11px;
            wrap: word-wrap;
        }
        Rectangle { vertical-stretch: 1; }
        HorizontalLayout {
            alignment: end;
            PillButton {
                label: "Close";
                clicked => { root.closed(); }
            }
        }
    }
}

// --- Top toolbar --------------------------------------------------------
component Toolbar inherits Rectangle {
    in property <string> status-text;
    in property <bool> connected;
    in property <string> device-summary;
    in property <bool> can-read;
    in property <bool> can-write;
    in property <bool> can-save;
    in property <[DeviceOption]> candidates;
    callback read-clicked();
    callback write-clicked();
    callback save-clicked();
    callback load-clicked();
    callback refresh-devices();
    callback device-picked(string /* serial */);
    callback about-clicked();
    callback open-log-folder();
    callback theme-toggled();

    background: Palette.bg-panel;
    border-color: Palette.border;
    border-width: 1px;
    border-radius: 6px;
    height: 56px;

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 12px;
        StatusDot {
            connected: root.connected;
            y: (parent.height - self.height) / 2;
        }
        LucideIcon {
            source: @image-url("../assets/icons/usb.svg");
            tint: root.connected ? Palette.success : Palette.text-dim;
            size: 16px;
            y: (parent.height - self.height) / 2;
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: root.status-text;
                color: Palette.text;
                font-size: 12px;
            }
            Text {
                text: root.device-summary;
                color: Palette.text-dim;
                font-size: 11px;
            }
        }
        PillButton {
            label: "Devices";
            icon-source: @image-url("../assets/icons/cpu.svg");
            show-chevron: true;
            enabled: true;
            clicked => {
                root.refresh-devices();
                picker-popup.show();
            }
            picker-popup := PopupWindow {
                x: 0;
                y: parent.height + 4px;
                width: 320px;
                close-policy: close-on-click-outside;
                Rectangle {
                    background: Palette.bg-panel;
                    border-color: Palette.border;
                    border-width: 1px;
                    border-radius: 6px;
                    VerticalLayout {
                        padding: 8px;
                        spacing: 4px;
                        Text {
                            text: "Connected HID candidates";
                            color: Palette.text-dim;
                            font-size: 11px;
                        }
                        if root.candidates.length == 0: Text {
                            text: "No FreeJoy / FreeJoyX devices found.";
                            color: Palette.text-dim;
                            font-size: 11px;
                        }
                        for opt in root.candidates: DevicePickerRow {
                            entry: opt;
                            picked => {
                                root.device-picked(opt.serial);
                                picker-popup.close();
                            }
                        }
                    }
                }
            }
        }
        Rectangle { horizontal-stretch: 1; }
        PillButton {
            label: "Load File…";
            icon-source: @image-url("../assets/icons/folder-open.svg");
            enabled: true;
            clicked => { root.load-clicked(); }
        }
        PillButton {
            label: "Save File…";
            icon-source: @image-url("../assets/icons/save.svg");
            enabled: root.can-save;
            clicked => { root.save-clicked(); }
        }
        PillButton {
            label: "Read Device";
            icon-source: @image-url("../assets/icons/download.svg");
            enabled: root.can-read;
            clicked => { root.read-clicked(); }
        }
        PillButton {
            label: "Write Device";
            icon-source: @image-url("../assets/icons/upload.svg");
            enabled: root.can-write;
            clicked => { root.write-clicked(); }
        }
        PillButton {
            label: "Help";
            icon-source: @image-url("../assets/icons/help-circle.svg");
            show-chevron: true;
            enabled: true;
            clicked => {
                help-popup.show();
            }
            help-popup := PopupWindow {
                x: 0;
                y: parent.height + 4px;
                width: 200px;
                close-policy: close-on-click-outside;
                Rectangle {
                    background: Palette.bg-panel;
                    border-color: Palette.border;
                    border-width: 1px;
                    border-radius: 6px;
                    VerticalLayout {
                        padding: 6px;
                        spacing: 4px;
                        Rectangle {
                            height: 28px;
                            background: about-ta.has-hover ? Palette.bg-cell-hover : transparent;
                            border-radius: 3px;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;
                                LucideIcon {
                                    source: @image-url("../assets/icons/help-circle.svg");
                                    tint: Palette.text-dim;
                                    size: 14px;
                                    y: (parent.height - self.height) / 2;
                                }
                                Text {
                                    text: "About FreeJoyXConfigurator";
                                    color: Palette.text;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }
                            about-ta := TouchArea {
                                clicked => {
                                    root.about-clicked();
                                    help-popup.close();
                                }
                            }
                        }
                        Rectangle {
                            height: 28px;
                            background: log-ta.has-hover ? Palette.bg-cell-hover : transparent;
                            border-radius: 3px;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;
                                LucideIcon {
                                    source: @image-url("../assets/icons/folder.svg");
                                    tint: Palette.text-dim;
                                    size: 14px;
                                    y: (parent.height - self.height) / 2;
                                }
                                Text {
                                    text: "Open Log Folder";
                                    color: Palette.text;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }
                            log-ta := TouchArea {
                                clicked => {
                                    root.open-log-folder();
                                    help-popup.close();
                                }
                            }
                        }
                        Rectangle {
                            height: 28px;
                            background: theme-ta.has-hover ? Palette.bg-cell-hover : transparent;
                            border-radius: 3px;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 8px;
                                LucideIcon {
                                    source: Palette.dark
                                        ? @image-url("../assets/icons/sun.svg")
                                        : @image-url("../assets/icons/moon.svg");
                                    tint: Palette.text-dim;
                                    size: 14px;
                                    y: (parent.height - self.height) / 2;
                                }
                                Text {
                                    text: Palette.dark ? "Switch to Light Mode" : "Switch to Dark Mode";
                                    color: Palette.text;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }
                            }
                            theme-ta := TouchArea {
                                clicked => {
                                    root.theme-toggled();
                                    help-popup.close();
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// --- Main window --------------------------------------------------------
export component AppWindow inherits Window {
    title: "FreeJoyX Configurator";
    icon: @image-url("../assets/icon.svg");
    background: Palette.bg-window;
    preferred-width: 1024px;
    preferred-height: 700px;
    min-width: 720px;
    min-height: 480px;

    in property <string> status-text: "starting…";
    in property <bool> connected: false;
    in property <string> device-summary: "no device";
    in property <bool> can-read: false;
    in property <bool> can-write: false;
    in property <bool> can-save: false;
    in property <[PinRow]> pins: [];
    in property <[string]> function-labels: [];
    in property <[AxisRow]> axes: [];
    in property <[ButtonRow]> buttons: [];
    in property <[ShiftSlot]> shifts: [];
    in property <[TimerField]> timers: [];
    in property <[EncoderRow]> soft-encoders: [];
    in property <[FastEncoderRow]> fast-encoders: [];
    in property <[ShiftRegRow]> shift-registers: [];
    in property <[DeviceOption]> device-candidates: [];
    in property <AdvancedModel> advanced;

    in property <int> toast-severity: 0; // 0 hidden, 1 info, 2 warn, 3 error
    in property <string> toast-message: "";
    in property <string> app-version: "";
    in property <string> build-rev: "";
    in property <string> supported-fw: "";
    in-out property <bool> about-open: false;

    // Button-type picker (issue #7). `entries` is static, set once at
    // startup; `blocked-info` and `current-type-index` refresh whenever
    // the picker opens.
    in property <[TypePickerEntry]> button-type-picker-entries: [];
    in property <[TypeBlockedInfo]> button-type-picker-blocked: [];
    in property <bool> button-type-picker-open: false;
    in property <int> button-type-picker-slot: 0;
    in property <int> button-type-picker-current: 0;

    // Buttons-tab filter state (issue #5). Rust owns the truth; these
    // are read-only mirrors so the strip can render its current state.
    in property <bool> buttons-hide-unused: false;
    in property <int> buttons-filter-physical: -1;
    in property <string> buttons-filter-category-label: "All";
    in property <int> buttons-visible-count: 128;

    callback read-clicked();
    callback write-clicked();
    callback save-clicked();
    callback load-clicked();
    callback pin-changed(int, int);
    callback axis-out-toggled(int);
    callback axis-inverted-toggled(int);
    callback axis-centered-toggled(int);
    callback axis-calib-min-edited(int, int);
    callback axis-calib-center-edited(int, int);
    callback axis-calib-max-edited(int, int);
    callback axis-filter-cycled(int);
    callback axis-deadband-edited(int, int);
    callback axis-dyn-deadband-toggled(int);
    callback axis-resolution-cycled(int);
    callback axis-channel-cycled(int);
    callback button-physical-edited(int, int);
    callback button-type-picker-opened(int /* slot */);
    callback button-type-picked(int /* slot */, int /* type-index */);
    callback button-type-picker-dismissed();
    callback button-shift-cycled(int);
    callback buttons-hide-unused-toggled();
    callback buttons-filter-physical-edited(int);
    callback buttons-filter-physical-cleared();
    callback buttons-filter-category-cycled();
    callback buttons-add-clicked();
    callback button-inverted-toggled(int);
    callback button-disabled-toggled(int);
    callback button-src-b-edited(int, int);
    callback button-op-cycled(int);
    callback button-debounce-cycled(int);
    callback shift-edited(int, int);
    callback timer-edited(int, int);
    callback soft-encoder-mode-cycled(int);
    callback fast-encoder-enabled-toggled(int);
    callback fast-encoder-mode-cycled(int);
    callback shift-reg-type-cycled(int);
    callback shift-reg-count-edited(int, int);
    callback refresh-devices();
    callback device-picked(string);
    callback advanced-name-edited(string);
    callback advanced-vid-edited(string);
    callback advanced-pid-edited(string);
    callback toast-dismissed();
    callback open-log-folder();
    callback theme-toggled();

    in-out property <int> active-tab: 0;

    VerticalLayout {
        padding: 14px;
        spacing: 10px;

        Toolbar {
            status-text: root.status-text;
            connected: root.connected;
            device-summary: root.device-summary;
            can-read: root.can-read;
            can-write: root.can-write;
            can-save: root.can-save;
            candidates: root.device-candidates;
            read-clicked => { root.read-clicked(); }
            write-clicked => { root.write-clicked(); }
            save-clicked => { root.save-clicked(); }
            load-clicked => { root.load-clicked(); }
            refresh-devices => { root.refresh-devices(); }
            device-picked(s) => { root.device-picked(s); }
            about-clicked => { root.about-open = true; }
            open-log-folder => { root.open-log-folder(); }
            theme-toggled => { root.theme-toggled(); }
        }

        if root.toast-severity > 0: ToastBanner {
            severity: root.toast-severity;
            message: root.toast-message;
            dismissed => { root.toast-dismissed(); }
        }

        // Tab strip
        Rectangle {
            height: 40px;
            HorizontalLayout {
                spacing: 4px;
                TabButton {
                    label: "Pins";
                    icon-source: @image-url("../assets/icons/pin.svg");
                    selected: root.active-tab == 0;
                    clicked => { root.active-tab = 0; }
                }
                TabButton {
                    label: "Axes";
                    icon-source: @image-url("../assets/icons/sliders-horizontal.svg");
                    selected: root.active-tab == 1;
                    clicked => { root.active-tab = 1; }
                }
                TabButton {
                    label: "Buttons + Logic";
                    icon-source: @image-url("../assets/icons/square-mouse-pointer.svg");
                    selected: root.active-tab == 2;
                    clicked => { root.active-tab = 2; }
                }
                TabButton {
                    label: "Shifts & Timers";
                    icon-source: @image-url("../assets/icons/timer.svg");
                    selected: root.active-tab == 3;
                    clicked => { root.active-tab = 3; }
                }
                TabButton {
                    label: "Encoders";
                    icon-source: @image-url("../assets/icons/rotate-cw.svg");
                    selected: root.active-tab == 4;
                    clicked => { root.active-tab = 4; }
                }
                TabButton {
                    label: "Shift Registers";
                    icon-source: @image-url("../assets/icons/layers.svg");
                    selected: root.active-tab == 5;
                    clicked => { root.active-tab = 5; }
                }
                TabButton {
                    label: "Advanced";
                    icon-source: @image-url("../assets/icons/settings.svg");
                    selected: root.active-tab == 6;
                    clicked => { root.active-tab = 6; }
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }

        // Tab body
        Rectangle {
            vertical-stretch: 1;
            background: Palette.bg-panel;
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 6px;

            if root.active-tab == 0: PinsTab {
                pins: root.pins;
                function-labels: root.function-labels;
                pin-changed(slot, fn) => { root.pin-changed(slot, fn); }
            }
            if root.active-tab == 1: AxesTab {
                axes: root.axes;
                out-toggled(s) => { root.axis-out-toggled(s); }
                inverted-toggled(s) => { root.axis-inverted-toggled(s); }
                centered-toggled(s) => { root.axis-centered-toggled(s); }
                calib-min-edited(s, v) => { root.axis-calib-min-edited(s, v); }
                calib-center-edited(s, v) => { root.axis-calib-center-edited(s, v); }
                calib-max-edited(s, v) => { root.axis-calib-max-edited(s, v); }
                filter-cycled(s) => { root.axis-filter-cycled(s); }
                deadband-edited(s, v) => { root.axis-deadband-edited(s, v); }
                dyn-deadband-toggled(s) => { root.axis-dyn-deadband-toggled(s); }
                resolution-cycled(s) => { root.axis-resolution-cycled(s); }
                channel-cycled(s) => { root.axis-channel-cycled(s); }
            }
            if root.active-tab == 2: ButtonsTab {
                buttons: root.buttons;
                hide-unused: root.buttons-hide-unused;
                filter-physical: root.buttons-filter-physical;
                filter-category-label: root.buttons-filter-category-label;
                visible-count: root.buttons-visible-count;
                physical-edited(s, v) => { root.button-physical-edited(s, v); }
                type-picker-opened(s) => { root.button-type-picker-opened(s); }
                shift-cycled(s) => { root.button-shift-cycled(s); }
                inverted-toggled(s) => { root.button-inverted-toggled(s); }
                disabled-toggled(s) => { root.button-disabled-toggled(s); }
                src-b-edited(s, v) => { root.button-src-b-edited(s, v); }
                op-cycled(s) => { root.button-op-cycled(s); }
                debounce-cycled(s) => { root.button-debounce-cycled(s); }
                hide-unused-toggled => { root.buttons-hide-unused-toggled(); }
                filter-physical-edited(v) => { root.buttons-filter-physical-edited(v); }
                filter-physical-cleared => { root.buttons-filter-physical-cleared(); }
                filter-category-cycled => { root.buttons-filter-category-cycled(); }
                add-button-clicked => { root.buttons-add-clicked(); }
            }
            if root.active-tab == 3: ShiftsTimersTab {
                shifts: root.shifts;
                timers: root.timers;
                shift-edited(i, v) => { root.shift-edited(i, v); }
                timer-edited(i, v) => { root.timer-edited(i, v); }
            }
            if root.active-tab == 4: EncodersTab {
                soft: root.soft-encoders;
                fast: root.fast-encoders;
                soft-mode-cycled(i) => { root.soft-encoder-mode-cycled(i); }
                fast-enabled-toggled(i) => { root.fast-encoder-enabled-toggled(i); }
                fast-mode-cycled(i) => { root.fast-encoder-mode-cycled(i); }
            }
            if root.active-tab == 5: ShiftRegsTab {
                registers: root.shift-registers;
                type-cycled(i) => { root.shift-reg-type-cycled(i); }
                count-edited(i, v) => { root.shift-reg-count-edited(i, v); }
            }
            if root.active-tab == 6: AdvancedTab {
                data: root.advanced;
                name-edited(s) => { root.advanced-name-edited(s); }
                vid-edited(s) => { root.advanced-vid-edited(s); }
                pid-edited(s) => { root.advanced-pid-edited(s); }
            }
        }
    }

    if root.about-open: Rectangle {
        background: #00000088;
        TouchArea {
            clicked => { root.about-open = false; }
        }
        AboutDialog {
            app-version: root.app-version;
            build-rev: root.build-rev;
            supported-fw: root.supported-fw;
            closed => { root.about-open = false; }
        }
    }

    if root.button-type-picker-open: TypePickerOverlay {
        entries: root.button-type-picker-entries;
        blocked-info: root.button-type-picker-blocked;
        slot: root.button-type-picker-slot;
        current-type-index: root.button-type-picker-current;
        picked(slot, type-index) => { root.button-type-picked(slot, type-index); }
        dismissed => { root.button-type-picker-dismissed(); }
    }
}
