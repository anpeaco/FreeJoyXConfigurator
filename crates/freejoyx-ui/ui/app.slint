// FreeJoyXConfigurator Slint shell.
//
// This file is the top of the UI tree: it imports every component and
// wires the AppWindow's property + callback surface to them. The body
// of each component lives in its own file under `ui/`.
//
// Visual style per Style.MD: dark cockpit panel (#2a2a32) on near-black
// window, amber accent (#ffcc33), light-grey text, single 1 px borders.
//
// --- UI rules -----------------------------------------------------------
//
// Row-cell sizing standard (applies to every in-row interactive control:
// buttons, dropdown cells, checkboxes, number fields, jump icons, …):
//
//   - Outer host is **26 px tall** — the row's nominal height.
//   - Inner visual is **22 px tall** — leaves 2 px of breathing space
//     top + bottom so adjacent rows don't kiss each other.
//   - Inner sits at `y: (parent.height - self.height) / 2` so it
//     y-centres inside the host regardless of the outer's actual
//     height. Setting a fixed `y:` doesn't work for layout children —
//     `HorizontalLayout` overrides any direct `y` on its items, so
//     the outer's height has to *match the row*, and the inner does
//     the centring.
//
// Any future button/cell that appears alongside the existing ones MUST
// follow this — otherwise the column won't line up.
//
// Tooltips: every button takes `in property <string> tooltip` and
// publishes hover state to the `TooltipState` global. The AppWindow
// hosts a single tooltip rectangle that renders the tooltip text at
// the hovered button's absolute position.

// --- Globals ------------------------------------------------------------
//
// Re-exported so the Rust side can access them via `Palette::get(window)`
// etc. Slint only emits Rust bindings for globals visible at the entry
// file's export surface.
import { Palette } from "globals/palette.slint";
import { TooltipState } from "globals/tooltip.slint";
import { Icons } from "globals/icons.slint";
export { Palette, TooltipState }

// --- Shared structs ----------------------------------------------------
import {
    AdvancedModel, AxisRow, ButtonRow, CategoryChip, DeviceOption,
    DropdownEntry, EncoderRow, FastEncoderRow, LogEntry, PinRow,
    ShiftRegRow, ShiftSlot, TimerField,
} from "types.slint";

// --- Tab strip + overlays ----------------------------------------------
import { TabButton } from "cells/tab_button.slint";
import { DropdownOverlay } from "cells/dropdown_overlay.slint";

// --- Tabs --------------------------------------------------------------
import { PinsTab } from "tabs/pins_tab.slint";
import { AxesTab } from "tabs/axes_tab.slint";
import { ButtonsTab } from "tabs/buttons_tab.slint";
import { ShiftsTimersTab } from "tabs/shifts_timers_tab.slint";
import { EncodersTab } from "tabs/encoders_tab.slint";
import { ShiftRegsTab } from "tabs/shift_regs_tab.slint";
import { AdvancedTab } from "tabs/advanced_tab.slint";
import { DebugTab } from "tabs/debug_tab.slint";

// --- Toolbar + dialogs -------------------------------------------------
import { Toolbar } from "dialogs/toolbar.slint";
import { ToastBanner } from "dialogs/toast_banner.slint";
import { AboutDialog } from "dialogs/about_dialog.slint";

// --- Main window --------------------------------------------------------
export component AppWindow inherits Window {
    title: "FreeJoyX Configurator";
    icon: @image-url("../assets/icon.svg");
    background: Palette.bg-window;
    preferred-width: 1024px;
    preferred-height: 700px;
    min-width: 960px;
    min-height: 540px;

    in property <string> status-text: "starting…";
    in property <bool> connected: false;
    in property <string> device-summary: "no device";
    in property <bool> can-read: false;
    in property <bool> can-write: false;
    in property <bool> can-save: false;
    // Identity-card fields surfaced on the new two-row toolbar. Rust
    // populates these from `DeviceCandidate` + `DeviceConfig`; the
    // Toolbar component renders them as the persistent device readout.
    in property <string> device-name: "—";
    in property <string> device-board: "—";
    in property <string> device-fw: "";
    in property <string> device-vid: "—";
    in property <string> device-pid: "—";
    in property <string> device-serial: "—";
    in property <int> pins-assigned: 0;
    in property <[PinRow]> pins: [];
    // Single global dropdown overlay (issue #15). Rust populates
    // these properties + sets `dropdown-open` when a cell requests the
    // overlay via `dropdown-requested`. The kind→entries dispatch
    // happens on the Rust side; Slint only sees the resolved entries
    // model and anchor coords.
    in property <[DropdownEntry]> dropdown-entries: [];
    in property <int> dropdown-current-value: -1;
    in property <length> dropdown-anchor-x: 0px;
    in property <length> dropdown-anchor-y: 0px;
    in property <length> dropdown-anchor-w: 100px;
    in property <bool> dropdown-open: false;
    in property <[AxisRow]> axes: [];
    // Rust pushes the computed sum of per-row heights (collapsed vs
    // expanded) so the Flickable's scrollable region matches the
    // actually-rendered content height.
    in property <length> axes-viewport-height: 1408px;
    // Pin-jump targets. -1 = no flash. Set on `pin-jump-clicked`,
    // cleared by a Rust-side timer ~1.5 s later. Per-target tab
    // bindings live below; the AppWindow holds the auth source so
    // tab-switch is atomic with the property push.
    in-out property <int> flash-axis-slot: -1;
    in-out property <int> flash-shift-reg-slot: -1;
    in-out property <int> flash-pin-slot: -1;
    /// Encoder→Buttons jump flash. Two slots (A and B of the encoder pair).
    /// -1 = no flash. Cleared together with the other flash slots by the
    /// pin-jump-flash timer in Rust.
    in-out property <int> flash-button-slot-a: -1;
    in-out property <int> flash-button-slot-b: -1;
    // Scroll target inside the Axes tab. Set together with
    // `axes-jump-tick` to drive the Flickable's viewport-y. Shift Regs
    // doesn't need a scroll target — only 4 rows, all visible at once.
    in-out property <length> axes-jump-y: 0px;
    in-out property <int> axes-jump-tick: 0;
    in property <[ButtonRow]> buttons: [];
    in property <[ShiftSlot]> shifts: [];
    in property <[TimerField]> timers: [];
    in property <[EncoderRow]> soft-encoders: [];
    in property <[FastEncoderRow]> fast-encoders: [];
    in property <[ShiftRegRow]> shift-registers: [];
    in property <[DeviceOption]> device-candidates: [];
    in property <AdvancedModel> advanced;
    // --- Debug tab plumbing ---------------------------------------
    in property <[LogEntry]> log-entries: [];
    in property <int> log-verbosity-index: 2;       // Info default
    in property <string> log-verbosity-label: "INFO";
    in property <[CategoryChip]> log-categories: [];
    in property <bool> log-auto-scroll: true;
    in property <bool> log-verbose-config: false;
    in property <int> log-total-count: 0;

    in property <int> toast-severity: 0; // 0 hidden, 1 info, 2 warn, 3 error
    in property <string> toast-message: "";
    in property <string> app-version: "";
    in property <string> build-rev: "";
    in property <string> supported-fw: "";
    in-out property <bool> about-open: false;

    // Buttons-tab filter state (issue #5). Rust owns the truth; these
    // are read-only mirrors so the strip can render its current state.
    in property <bool> buttons-hide-unused: false;
    in property <int> buttons-filter-physical: -1;
    in property <string> buttons-filter-category-label: "All";
    in property <int> buttons-visible-count: 128;
    /// True while the buttons-tab "press to filter" mode is armed.
    /// Each observed press re-narrows `buttons-filter-physical` and
    /// scrolls the row into view; the arm stays on until the user
    /// toggles it off, switches tab, or clicks a per-row Physical cell.
    in property <bool> buttons-filter-arm: false;
    /// Buttons-tab scroll target driven by press-to-filter captures.
    /// Together with `buttons-jump-tick`, mirrors the axes-tab jump
    /// pattern.
    in property <length> buttons-jump-y: 0px;
    in property <int> buttons-jump-tick: 0;

    callback read-clicked();
    callback write-clicked();
    callback save-clicked();
    callback load-clicked();
    callback axis-out-toggled(int);
    callback axis-inverted-toggled(int);
    callback axis-centered-toggled(int);
    callback axis-calib-min-edited(int, int);
    callback axis-calib-center-edited(int, int);
    callback axis-calib-max-edited(int, int);
    callback axis-deadband-edited(int, int);
    callback axis-dyn-deadband-toggled(int);
    callback axis-calibrate-toggled(int);
    callback axis-reset-clicked(int);
    callback axis-set-center-clicked(int);
    callback axis-detect-toggled(int);
    /// Phase 1 advanced axes: extended-panel toggle and the three
    /// new numeric edits in the Function group.
    callback axis-extended-toggled(int);
    callback axis-offset-edited(int, int);
    callback axis-step-div-edited(int, int);
    callback axis-prescaler-edited(int, int);
    /// Phase 2 advanced axes: axis-triggered buttons + buttons-from-axes count.
    callback axis-buttons-from-axes-edited(int, int);
    callback axis-btn1-slot-edited(int, int);
    callback axis-btn2-slot-edited(int, int);
    callback axis-btn3-slot-edited(int, int);
    /// Pins-tab "→" jump button. The argument is the wire-slot of the
    /// source pin; Rust resolves it to (tab, row) and sets the
    /// matching `flash-*-slot` + scroll target.
    callback pin-jump-clicked(int /* wire-slot */);
    /// Reverse jumps. Argument is the row's own slot index in its
    /// home tab — Rust resolves it to the matching pin wire-slot
    /// and sets `flash-pin-slot` + active-tab=0 (Pins).
    callback axis-back-to-pin-clicked(int /* axis slot */);
    callback shift-reg-back-to-pin-clicked(int /* sr slot */);
    callback button-physical-edited(int, int);
    callback button-physical-armed-changed(int /* slot */, bool /* armed */);
    callback buttons-hide-unused-toggled();
    callback buttons-filter-physical-edited(int);
    callback buttons-filter-physical-cleared();
    /// Toggle the buttons-tab "press to filter" arm. When on, every
    /// physical button press observed by `ParamsTick` re-narrows
    /// `buttons-filter-physical` and scrolls the matching row into
    /// view; the arm stays on across presses.
    callback buttons-filter-arm-toggled();
    /// Unconditional disarm — fired on tab switch and when the user
    /// arms a per-row Physical cell. Rust mirrors the cleared state
    /// back into `buttons-filter-arm`.
    callback buttons-filter-disarm();
    callback buttons-add-clicked();
    callback button-inverted-toggled(int);
    callback button-disabled-toggled(int);
    callback button-src-b-edited(int, int);
    callback button-src-b-armed-changed(int /* slot */, bool /* armed */);
    callback shift-edited(int, int);
    callback timer-edited(int, int);
    callback fast-encoder-enabled-toggled(int);
    callback encoder-swap-pair-clicked(int);
    /// Soft-encoder "→ buttons" jump. Argument is the encoder's wire-slot
    /// index. Rust resolves it to the paired A/B button slots and pulses
    /// them on the Buttons tab.
    callback encoder-jump-to-buttons-clicked(int /* wire-slot */);
    callback shift-reg-count-edited(int, int);
    callback shift-reg-chip-size-edited(int /* sr slot */, int /* buttons per chip */);
    callback shift-reg-chip-count-edited(int /* sr slot */, int /* chip count */);
    /// Single dropdown open path (issue #15). `kind` identifies the
    /// picker, `slot` the row inside it (or -1 for non-row pickers).
    /// `abs-x` / `abs-y` are the cell's screen coordinates relative to
    /// AppWindow; `width` is the resolved popup width. Rust dispatches
    /// per `kind` to set entries + current-value, then sets
    /// `dropdown-open: true`.
    callback dropdown-requested(int /* kind */, int /* slot */, length /* abs-x */, length /* abs-y */, length /* width */);
    /// Single dropdown pick path. Rust uses the last `dropdown-requested`'s
    /// `kind` + `slot` to dispatch the picked value.
    callback dropdown-picked(int /* value */);
    callback dropdown-dismissed();
    callback refresh-devices();
    callback device-picked(string);
    callback log-category-toggled(int /* category index */);
    callback log-clear-clicked();
    callback log-export-clicked();
    callback log-auto-scroll-toggled();
    callback log-verbose-config-toggled();
    callback advanced-name-edited(string);
    callback advanced-vid-edited(string);
    callback advanced-pid-edited(string);
    callback toast-dismissed();
    callback open-log-folder();
    callback theme-toggled();

    in-out property <int> active-tab: 0;

    // Per-tab "configured" indicators. Rust recomputes these on every
    // `DeviceConfig` change (read, file load, dropdown pick, gesture
    // capture mutation) and pushes the bool here. Drives the dot on
    // the right edge of each `TabButton`. Tabs without a meaningful
    // "has content" question (Advanced, Debug) don't get a property.
    in property <bool> pins-has-content: false;
    in property <bool> axes-has-content: false;
    in property <bool> buttons-has-content: false;
    in property <bool> shifts-has-content: false;
    in property <bool> encoders-has-content: false;
    in property <bool> shift-regs-has-content: false;

    // Clear any stuck tooltip when the active tab changes. Jump
    // buttons swap tabs out from under the hovered button — its
    // TouchArea is destroyed before `has-hover` flips to false, so
    // the per-button `changed hovered =>` clear never fires. Same
    // story when the user clicks the tab strip directly while hovering
    // a control. Resetting `TooltipState` here covers every path.
    changed active-tab => {
        TooltipState.visible = false;
        TooltipState.text = "";
        // Buttons-tab press-to-filter only makes sense while that tab
        // is visible; tear it down on any tab change.
        if (root.buttons-filter-arm) {
            root.buttons-filter-disarm();
        }
    }

    VerticalLayout {
        padding: 14px;
        spacing: 10px;

        Toolbar {
            connected: root.connected;
            can-read: root.can-read;
            can-write: root.can-write;
            can-save: root.can-save;
            candidates: root.device-candidates;
            device-name: root.device-name;
            device-board: root.device-board;
            device-fw: root.device-fw;
            device-vid: root.device-vid;
            device-pid: root.device-pid;
            device-serial: root.device-serial;
            pins-assigned: root.pins-assigned;
            read-clicked => { root.read-clicked(); }
            write-clicked => { root.write-clicked(); }
            save-clicked => { root.save-clicked(); }
            load-clicked => { root.load-clicked(); }
            refresh-devices => { root.refresh-devices(); }
            device-picked(s) => { root.device-picked(s); }
            about-clicked => { root.about-open = true; }
            open-log-folder => { root.open-log-folder(); }
            theme-toggled => { root.theme-toggled(); }
        }

        if root.toast-severity > 0: ToastBanner {
            severity: root.toast-severity;
            message: root.toast-message;
            dismissed => { root.toast-dismissed(); }
        }

        // Tab strip
        Rectangle {
            height: 40px;
            HorizontalLayout {
                spacing: 4px;
                TabButton {
                    label: "Pins";
                    icon-source: Icons.pins;
                    selected: root.active-tab == 0;
                    has-content: root.pins-has-content;
                    clicked => { root.active-tab = 0; }
                }
                TabButton {
                    label: "Axes";
                    icon-source: Icons.axes;
                    selected: root.active-tab == 1;
                    has-content: root.axes-has-content;
                    clicked => { root.active-tab = 1; }
                }
                TabButton {
                    label: "Buttons";
                    icon-source: Icons.buttons;
                    selected: root.active-tab == 2;
                    has-content: root.buttons-has-content;
                    clicked => { root.active-tab = 2; }
                }
                TabButton {
                    label: "Shifts";
                    icon-source: Icons.shifts-timers;
                    selected: root.active-tab == 3;
                    has-content: root.shifts-has-content;
                    clicked => { root.active-tab = 3; }
                }
                TabButton {
                    label: "Encoders";
                    icon-source: Icons.encoders;
                    selected: root.active-tab == 4;
                    has-content: root.encoders-has-content;
                    clicked => { root.active-tab = 4; }
                }
                TabButton {
                    label: "Shift Registers";
                    icon-source: Icons.shift-registers;
                    selected: root.active-tab == 5;
                    has-content: root.shift-regs-has-content;
                    clicked => { root.active-tab = 5; }
                }
                TabButton {
                    label: "Advanced";
                    icon-source: Icons.advanced;
                    selected: root.active-tab == 6;
                    clicked => { root.active-tab = 6; }
                }
                TabButton {
                    label: "Debug";
                    icon-source: Icons.debug;
                    selected: root.active-tab == 7;
                    clicked => { root.active-tab = 7; }
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }

        // Tab body. Heavy tabs (Pins / Axes / Buttons) are instantiated
        // once at startup and toggled via `visible:` so switching to
        // them is a property flip instead of a teardown + rebuild of
        // ~1000 Slint elements (the Buttons tab alone has 128 rows × ~10
        // child cells). Lighter tabs stay on the `if` pattern so they
        // only allocate when first opened. Side benefit: the alive tabs
        // remember their scroll position across switches.
        Rectangle {
            vertical-stretch: 1;
            background: Palette.bg-panel;
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 6px;

            PinsTab {
                visible: root.active-tab == 0;
                width: parent.width;
                height: parent.height;
                pins: root.pins;
                flash-slot: root.flash-pin-slot;
                dropdown-requested(k, s, x, y, w) => {
                    root.dropdown-requested(k, s, x, y, w);
                }
                jump-clicked(s) => { root.pin-jump-clicked(s); }
            }
            AxesTab {
                visible: root.active-tab == 1;
                width: parent.width;
                height: parent.height;
                axes: root.axes;
                viewport-height: root.axes-viewport-height;
                flash-slot: root.flash-axis-slot;
                jump-y: root.axes-jump-y;
                jump-tick: root.axes-jump-tick;
                out-toggled(s) => { root.axis-out-toggled(s); }
                inverted-toggled(s) => { root.axis-inverted-toggled(s); }
                centered-toggled(s) => { root.axis-centered-toggled(s); }
                calib-min-edited(s, v) => { root.axis-calib-min-edited(s, v); }
                calib-center-edited(s, v) => { root.axis-calib-center-edited(s, v); }
                calib-max-edited(s, v) => { root.axis-calib-max-edited(s, v); }
                deadband-edited(s, v) => { root.axis-deadband-edited(s, v); }
                dyn-deadband-toggled(s) => { root.axis-dyn-deadband-toggled(s); }
                calibrate-toggled(s) => { root.axis-calibrate-toggled(s); }
                reset-clicked(s) => { root.axis-reset-clicked(s); }
                set-center-clicked(s) => { root.axis-set-center-clicked(s); }
                detect-toggled(s) => { root.axis-detect-toggled(s); }
                back-to-pin-clicked(s) => { root.axis-back-to-pin-clicked(s); }
                extended-toggled(s) => { root.axis-extended-toggled(s); }
                offset-edited(s, v) => { root.axis-offset-edited(s, v); }
                step-div-edited(s, v) => { root.axis-step-div-edited(s, v); }
                prescaler-edited(s, v) => { root.axis-prescaler-edited(s, v); }
                buttons-from-axes-edited(s, v) => { root.axis-buttons-from-axes-edited(s, v); }
                btn1-slot-edited(s, v) => { root.axis-btn1-slot-edited(s, v); }
                btn2-slot-edited(s, v) => { root.axis-btn2-slot-edited(s, v); }
                btn3-slot-edited(s, v) => { root.axis-btn3-slot-edited(s, v); }
                dropdown-requested(k, s, x, y, w) => {
                    root.dropdown-requested(k, s, x, y, w);
                }
            }
            ButtonsTab {
                visible: root.active-tab == 2;
                width: parent.width;
                height: parent.height;
                buttons: root.buttons;
                hide-unused: root.buttons-hide-unused;
                filter-physical: root.buttons-filter-physical;
                filter-category-label: root.buttons-filter-category-label;
                visible-count: root.buttons-visible-count;
                filter-arm: root.buttons-filter-arm;
                jump-y: root.buttons-jump-y;
                jump-tick: root.buttons-jump-tick;
                flash-slot-a: root.flash-button-slot-a;
                flash-slot-b: root.flash-button-slot-b;
                physical-edited(s, v) => { root.button-physical-edited(s, v); }
                physical-armed-changed(s, a) => { root.button-physical-armed-changed(s, a); }
                inverted-toggled(s) => { root.button-inverted-toggled(s); }
                disabled-toggled(s) => { root.button-disabled-toggled(s); }
                src-b-edited(s, v) => { root.button-src-b-edited(s, v); }
                src-b-armed-changed(s, a) => { root.button-src-b-armed-changed(s, a); }
                hide-unused-toggled => { root.buttons-hide-unused-toggled(); }
                filter-physical-edited(v) => { root.buttons-filter-physical-edited(v); }
                filter-physical-cleared => { root.buttons-filter-physical-cleared(); }
                filter-arm-toggled => { root.buttons-filter-arm-toggled(); }
                dropdown-requested(k, s, x, y, w) => {
                    root.dropdown-requested(k, s, x, y, w);
                }
                add-button-clicked => { root.buttons-add-clicked(); }
            }
            if root.active-tab == 3: ShiftsTimersTab {
                width: parent.width;
                height: parent.height;
                shifts: root.shifts;
                timers: root.timers;
                shift-edited(i, v) => { root.shift-edited(i, v); }
                timer-edited(i, v) => { root.timer-edited(i, v); }
            }
            if root.active-tab == 4: EncodersTab {
                width: parent.width;
                height: parent.height;
                soft: root.soft-encoders;
                fast: root.fast-encoders;
                fast-enabled-toggled(i) => { root.fast-encoder-enabled-toggled(i); }
                dropdown-requested(k, s, x, y, w) => {
                    root.dropdown-requested(k, s, x, y, w);
                }
                swap-pair-clicked(s) => { root.encoder-swap-pair-clicked(s); }
                jump-to-buttons-clicked(s) => { root.encoder-jump-to-buttons-clicked(s); }
            }
            if root.active-tab == 5: ShiftRegsTab {
                width: parent.width;
                height: parent.height;
                registers: root.shift-registers;
                flash-slot: root.flash-shift-reg-slot;
                count-edited(i, v) => { root.shift-reg-count-edited(i, v); }
                chip-size-edited(i, v) => { root.shift-reg-chip-size-edited(i, v); }
                chip-count-edited(i, v) => { root.shift-reg-chip-count-edited(i, v); }
                dropdown-requested(k, s, x, y, w) => {
                    root.dropdown-requested(k, s, x, y, w);
                }
                back-to-pin-clicked(s) => { root.shift-reg-back-to-pin-clicked(s); }
            }
            if root.active-tab == 6: AdvancedTab {
                width: parent.width;
                height: parent.height;
                data: root.advanced;
                name-edited(s) => { root.advanced-name-edited(s); }
                vid-edited(s) => { root.advanced-vid-edited(s); }
                pid-edited(s) => { root.advanced-pid-edited(s); }
            }
            if root.active-tab == 7: DebugTab {
                width: parent.width;
                height: parent.height;
                entries: root.log-entries;
                verbosity-index: root.log-verbosity-index;
                verbosity-label: root.log-verbosity-label;
                categories: root.log-categories;
                auto-scroll: root.log-auto-scroll;
                verbose-config: root.log-verbose-config;
                total-count: root.log-total-count;
                verbosity-clicked(k, s, x, y, w) => {
                    root.dropdown-requested(k, s, x, y, w);
                }
                category-toggled(i) => { root.log-category-toggled(i); }
                clear-clicked => { root.log-clear-clicked(); }
                export-clicked => { root.log-export-clicked(); }
                auto-scroll-toggled => { root.log-auto-scroll-toggled(); }
                verbose-config-toggled => { root.log-verbose-config-toggled(); }
            }
        }
    }

    if root.about-open: Rectangle {
        background: #00000088;
        TouchArea {
            clicked => { root.about-open = false; }
        }
        AboutDialog {
            app-version: root.app-version;
            build-rev: root.build-rev;
            supported-fw: root.supported-fw;
            closed => { root.about-open = false; }
        }
    }

    // Single global dropdown overlay (issue #15). Rendered above
    // everything else so it floats over tabs / Flickable rows. Anchor
    // coords are AppWindow-local — cells supply them via their own
    // `absolute-position`.
    if root.dropdown-open: DropdownOverlay {
        anchor-x: root.dropdown-anchor-x;
        anchor-y: root.dropdown-anchor-y;
        anchor-w: root.dropdown-anchor-w;
        entries: root.dropdown-entries;
        current-value: root.dropdown-current-value;
        picked(v) => { root.dropdown-picked(v); }
        dismissed => { root.dropdown-dismissed(); }
    }

    // Tooltip overlay. Rendered last so it floats above every tab,
    // toolbar, Flickable, and the dropdown overlay. The pill text is
    // populated by hovering any control with a `tooltip` property
    // (see `TooltipState` in globals/tooltip.slint). Pointer events
    // pass through so hovering does not steal click focus from
    // underlying buttons / dropdowns.
    if TooltipState.visible && TooltipState.text != "": Rectangle {
        x: TooltipState.anchor-x;
        y: TooltipState.anchor-y;
        width: tt-text.preferred-width + 14px;
        height: tt-text.preferred-height + 8px;
        background: Palette.bg-cell;
        border-color: Palette.border;
        border-width: 1px;
        border-radius: 3px;
        z: 100;
        tt-text := Text {
            text: TooltipState.text;
            color: Palette.text;
            font-size: 11px;
            x: 7px;
            y: 4px;
        }
    }
}
