import { Palette } from "../globals/palette.slint";
import { Icons } from "../globals/icons.slint";
import { DeviceOption } from "../types.slint";
import { LucideIcon } from "../cells/lucide_icon.slint";
import { PillButton } from "../cells/pill_button.slint";
import { StatusDot } from "../cells/status_dot.slint";
import { DevicePickerRow } from "device_picker.slint";

// Two-row toolbar (UX backlog #8). Top row: device-identity card —
// fixed-width fields so the layout never reflows as state changes.
// Bottom row: action clusters — Devices pinned left, Help pinned
// right, file ops + device I/O clustered in the middle with flex
// spacers on both sides so the cluster centres stably.
//
// The persistent `status-text` from the old toolbar has been retired
// — every value it carried (firmware version, board, pins assigned)
// now lives explicitly in the identity card, and transient errors
// keep going through the existing toast system.
export component Toolbar inherits Rectangle {
    in property <bool> connected;
    in property <bool> can-read;
    in property <bool> can-write;
    in property <bool> can-save;
    in property <[DeviceOption]> candidates;
    // Identity card fields. All strings; Rust formats them so the
    // toolbar stays pure presentation. Empty / "—" when disconnected.
    in property <string> device-name;
    in property <string> device-board;
    in property <string> device-fw;
    in property <string> device-vid;
    in property <string> device-pid;
    in property <string> device-serial;
    in property <int> pins-assigned;
    in property <int> pins-total: 30;
    callback read-clicked();
    callback write-clicked();
    callback save-clicked();
    callback load-clicked();
    callback refresh-devices();
    callback device-picked(string /* serial */);
    callback about-clicked();
    callback open-log-folder();
    callback theme-toggled();

    background: Palette.bg-panel;
    border-color: Palette.border;
    border-width: 1px;
    border-radius: 6px;
    height: 92px;

    VerticalLayout {
        padding-left: 14px;
        padding-right: 14px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 6px;

        // -- Identity card row -----------------------------------
        Rectangle {
            height: 42px;
            HorizontalLayout {
                spacing: 10px;
                StatusDot {
                    connected: root.connected;
                    y: (parent.height - self.height) / 2;
                }
                VerticalLayout {
                    alignment: center;
                    spacing: 2px;
                    // Line 1 — name + board + firmware.
                    HorizontalLayout {
                        spacing: 10px;
                        Text {
                            text: root.connected ? root.device-name : "No device";
                            color: root.connected ? Palette.text : Palette.text-dim;
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        if root.connected: Text {
                            text: "·";
                            color: Palette.text-dim;
                            font-size: 14px;
                            vertical-alignment: center;
                        }
                        if root.connected: Text {
                            text: root.device-board;
                            color: Palette.accent;
                            font-size: 13px;
                            font-weight: 500;
                            vertical-alignment: center;
                        }
                        if root.connected && root.device-fw != "": Text {
                            text: "·";
                            color: Palette.text-dim;
                            font-size: 14px;
                            vertical-alignment: center;
                        }
                        if root.connected && root.device-fw != "": Text {
                            text: root.device-fw;
                            color: Palette.text-dim;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                    // Line 2 — VID/PID + serial (connected) or hint (disconnected).
                    Text {
                        text: root.connected
                            ? ("VID " + root.device-vid + " / PID " + root.device-pid
                                + "  ·  Serial " + root.device-serial)
                            : "Plug in a FreeJoyX-compatible board to begin.";
                        color: Palette.text-dim;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                // Unsaved chip — surfaces when there are unwritten
                // changes. Sits on the right edge of the identity row
                // so it reads as device-status-adjacent, not as a
                // toolbar action.
                if root.can-save: Rectangle {
                    width: 86px;
                    height: 22px;
                    y: (parent.height - self.height) / 2;
                    background: Palette.bg-warn;
                    border-color: Palette.accent;
                    border-width: 1px;
                    border-radius: 11px;
                    HorizontalLayout {
                        alignment: center;
                        spacing: 4px;
                        LucideIcon {
                            source: Icons.unsaved;
                            tint: Palette.accent;
                            size: 12px;
                            y: (parent.height - self.height) / 2;
                        }
                        Text {
                            text: "Unsaved";
                            color: Palette.text;
                            font-size: 11px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
                // Pins-assigned counter — connected-only.
                if root.connected: VerticalLayout {
                    alignment: center;
                    spacing: 0px;
                    Text {
                        text: root.pins-assigned + " / " + root.pins-total;
                        color: Palette.text;
                        font-size: 13px;
                        font-weight: 600;
                        horizontal-alignment: right;
                    }
                    Text {
                        text: "pins assigned";
                        color: Palette.text-dim;
                        font-size: 10px;
                        horizontal-alignment: right;
                    }
                }
            }
        }

        // -- Action row ------------------------------------------
        Rectangle {
            height: 32px;
            HorizontalLayout {
                spacing: 8px;
                // Devices picker — pinned left.
                PillButton {
                    label: "Devices";
                    icon-source: Icons.devices;
                    show-chevron: true;
                    enabled: true;
                    y: (parent.height - self.height) / 2;
                    clicked => {
                        root.refresh-devices();
                        picker-popup.show();
                    }
                    picker-popup := PopupWindow {
                        x: 0;
                        y: parent.height + 4px;
                        width: 320px;
                        close-policy: close-on-click-outside;
                        Rectangle {
                            background: Palette.bg-panel;
                            border-color: Palette.border;
                            border-width: 1px;
                            border-radius: 6px;
                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;
                                Text {
                                    text: "Connected HID candidates";
                                    color: Palette.text-dim;
                                    font-size: 11px;
                                }
                                if root.candidates.length == 0: Text {
                                    text: "No FreeJoy / FreeJoyX devices found.";
                                    color: Palette.text-dim;
                                    font-size: 11px;
                                }
                                for opt in root.candidates: DevicePickerRow {
                                    entry: opt;
                                    picked => {
                                        root.device-picked(opt.serial);
                                        picker-popup.close();
                                    }
                                }
                            }
                        }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                // Middle cluster — file ops then device I/O, with a
                // small visual gap between the two functional groups.
                PillButton {
                    label: "Load File…";
                    icon-source: Icons.load-file;
                    enabled: true;
                    y: (parent.height - self.height) / 2;
                    clicked => { root.load-clicked(); }
                }
                PillButton {
                    label: "Save File…";
                    icon-source: Icons.save-file;
                    enabled: root.can-save;
                    y: (parent.height - self.height) / 2;
                    clicked => { root.save-clicked(); }
                }
                Rectangle { width: 12px; }
                PillButton {
                    label: "Read Device";
                    icon-source: Icons.read-device;
                    enabled: root.can-read;
                    y: (parent.height - self.height) / 2;
                    clicked => { root.read-clicked(); }
                }
                PillButton {
                    label: "Write Device";
                    icon-source: Icons.write-device;
                    enabled: root.can-write;
                    y: (parent.height - self.height) / 2;
                    clicked => { root.write-clicked(); }
                }
                Rectangle { horizontal-stretch: 1; }
                // Help — pinned right.
                PillButton {
                    label: "Help";
                    icon-source: Icons.help;
                    show-chevron: true;
                    enabled: true;
                    y: (parent.height - self.height) / 2;
                    clicked => {
                        help-popup.show();
                    }
                    help-popup := PopupWindow {
                        x: -80px;
                        y: parent.height + 4px;
                        width: 200px;
                        close-policy: close-on-click-outside;
                        Rectangle {
                            background: Palette.bg-panel;
                            border-color: Palette.border;
                            border-width: 1px;
                            border-radius: 6px;
                            VerticalLayout {
                                padding: 6px;
                                spacing: 4px;
                                Rectangle {
                                    height: 28px;
                                    background: about-ta.has-hover ? Palette.bg-cell-hover : transparent;
                                    border-radius: 3px;
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 8px;
                                        LucideIcon {
                                            source: Icons.help;
                                            tint: Palette.text-dim;
                                            size: 14px;
                                            y: (parent.height - self.height) / 2;
                                        }
                                        Text {
                                            text: "About FreeJoyXConfigurator";
                                            color: Palette.text;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    about-ta := TouchArea {
                                        clicked => {
                                            root.about-clicked();
                                            help-popup.close();
                                        }
                                    }
                                }
                                Rectangle {
                                    height: 28px;
                                    background: log-ta.has-hover ? Palette.bg-cell-hover : transparent;
                                    border-radius: 3px;
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 8px;
                                        LucideIcon {
                                            source: Icons.log-folder;
                                            tint: Palette.text-dim;
                                            size: 14px;
                                            y: (parent.height - self.height) / 2;
                                        }
                                        Text {
                                            text: "Open Log Folder";
                                            color: Palette.text;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    log-ta := TouchArea {
                                        clicked => {
                                            root.open-log-folder();
                                            help-popup.close();
                                        }
                                    }
                                }
                                Rectangle {
                                    height: 28px;
                                    background: theme-ta.has-hover ? Palette.bg-cell-hover : transparent;
                                    border-radius: 3px;
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 8px;
                                        LucideIcon {
                                            source: Palette.dark ? Icons.theme-light : Icons.theme-dark;
                                            tint: Palette.text-dim;
                                            size: 14px;
                                            y: (parent.height - self.height) / 2;
                                        }
                                        Text {
                                            text: Palette.dark ? "Switch to Light Mode" : "Switch to Dark Mode";
                                            color: Palette.text;
                                            font-size: 12px;
                                            vertical-alignment: center;
                                        }
                                    }
                                    theme-ta := TouchArea {
                                        clicked => {
                                            root.theme-toggled();
                                            help-popup.close();
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
